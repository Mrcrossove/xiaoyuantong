generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchoolContent {
  id             Int      @id @default(autoincrement())
  school         String
  userCount      Int
  postCount      Int
  storeCount     Int
  orderCount     Int
  gmv            Float
  verifyPassRate String
  status         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AdminRole {
  id          Int         @id @default(autoincrement())
  code        String      @unique
  name        String
  scopeType   String
  status      String
  permissions Json
  menuPaths   Json
  users       AdminUser[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AdminUser {
  id          Int                @id @default(autoincrement())
  account     String             @unique
  password    String
  name        String
  status      String
  schools     Json
  lastLoginAt DateTime?
  mustChangePassword Boolean     @default(false)
  passwordUpdatedAt DateTime?
  initialPasswordSentAt DateTime?
  roleId      Int
  role        AdminRole          @relation(fields: [roleId], references: [id])
  reviews     UserVerification[] @relation("VerificationReviewer")
  postReviews MiniPost[]         @relation("MiniPostReviewer")
  postReports MiniPostReport[]   @relation("PostReportReviewer")
  refunds     MiniRefundRecord[] @relation("RefundReviewer")
  reviewedSchoolAdminApplications   SchoolAdminApplication[] @relation("SchoolAdminReviewer")
  assignedSchoolAdminApplications   SchoolAdminApplication[] @relation("SchoolAdminAssignedAdmin")
  storeChangeLogs AdminStoreChangeLog[]
  requestedStoreProductApprovals StoreProductApproval[] @relation("StoreProductApprovalRequester")
  reviewedStoreProductApprovals  StoreProductApproval[] @relation("StoreProductApprovalReviewer")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model MiniUser {
  id            Int                @id @default(autoincrement())
  deviceId      String             @unique
  openid        String?            @unique
  unionId       String?
  avatarUrl     String?
  nickname      String
  phone         String?
  school        String?
  verifyStatus  String             @default("未认证")
  verifiedAt    DateTime?
  verifications UserVerification[]
  posts         MiniPost[]
  shopApplies   MiniShopApply[]
  favorites     MiniFavorite[]
  addresses     MiniAddress[]
  orders        MiniOrder[]
  refunds       MiniRefundRecord[] @relation("MiniRefundApplicant")
  walletAccount MiniWalletAccount?
  withdraws     MiniWithdrawRecord[]
  postLikes     MiniPostLike[]
  postComments  MiniPostComment[]
  postReports   MiniPostReport[]   @relation("MiniPostReportReporter")
  messages      MiniMessage[]     @relation("MiniMessageReceiver")
  messageReads  MiniMessageRead[]
  messageDeletes MiniMessageDelete[]
  merchantReferrals MerchantReferral[]
  ownedStores   MiniStore[]       @relation("MiniStoreOwner")
  merchantAccount MerchantAccount?
  schoolAdminApplications SchoolAdminApplication[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model SchoolAdminApplication {
  id                  Int        @id @default(autoincrement())
  userId              Int
  user                MiniUser   @relation(fields: [userId], references: [id])
  school              String
  teamSize            Int
  contact             String
  status              String
  reviewNote          String?
  assignedAdminUserId Int?
  assignedAdminUser   AdminUser? @relation("SchoolAdminAssignedAdmin", fields: [assignedAdminUserId], references: [id])
  reviewedById        Int?
  reviewedBy          AdminUser? @relation("SchoolAdminReviewer", fields: [reviewedById], references: [id])
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([school, status])
  @@index([userId, createdAt])
}

model MiniRiskEvent {
  id        Int      @id @default(autoincrement())
  userId    Int?
  scene     String
  action    String
  level     String
  content   String
  hitRules  Json
  decision  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, scene])
  @@index([createdAt])
}

model UserVerification {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         MiniUser   @relation(fields: [userId], references: [id])
  realName     String
  phone        String
  school       String
  status       String
  reviewerId   Int?
  reviewer     AdminUser? @relation("VerificationReviewer", fields: [reviewerId], references: [id])
  reviewNote   String?
  reviewedAt   DateTime?
  submitSource String     @default("小程序")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model MiniPost {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         MiniUser   @relation(fields: [userId], references: [id])
  school       String
  authorName   String
  displayName  String?
  primaryCategory String?
  category     String
  title        String
  content      String
  images       Json
  contacts     Json
  isAnonymous  Boolean    @default(false)
  onlyCampus   Boolean    @default(true)
  status       String
  reviewNote   String?
  reviewerId   Int?
  reviewer     AdminUser? @relation("MiniPostReviewer", fields: [reviewerId], references: [id])
  reviewedAt   DateTime?
  likeCount    Int        @default(0)
  commentCount Int        @default(0)
  viewCount    Int        @default(0)
  likes        MiniPostLike[]
  comments     MiniPostComment[]
  reports      MiniPostReport[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model MiniPostLike {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      MiniPost @relation(fields: [postId], references: [id])
  userId    Int
  user      MiniUser @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([postId, userId])
}

model MiniPostComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      MiniPost @relation(fields: [postId], references: [id])
  userId    Int
  user      MiniUser @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, id])
}

model MiniStore {
  id           Int      @id @default(autoincrement())
  detailId     String   @unique
  ownerUserId  Int?
  ownerUser    MiniUser? @relation("MiniStoreOwner", fields: [ownerUserId], references: [id])
  school       String
  name         String
  groupKey     String
  groupLabel   String
  sectionKey   String
  sectionLabel String
  subtitle     String
  rating       Float
  monthlySales String
  distance     String
  delivery     String
  priceText    String
  tags         Json
  badge        String
  cover        String
  title        String
  notice       String
  phone        String
  address      String
  latitude     Float?
  longitude    Float?
  locationName String?
  locationAddress String?
  soldText     String
  amountText   String
  productCount Int
  banners      Json
  products     Json
  wechatSubMchId String?
  wechatSubMchStatus String @default("not_invited")
  commissionRate Float?
  profitSharingEnabled Boolean @default(true)
  settlementMode String @default("auto")
  merchantContactName String?
  merchantContactPhone String?
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  merchantAccount MerchantAccount?
  productRows  MiniStoreProduct[]
  productCategories MiniStoreProductCategory[]
  serviceSchools MiniStoreServiceSchool[]
  changeLogs   AdminStoreChangeLog[]
  productApprovals StoreProductApproval[]
}

model MiniStoreServiceSchool {
  id        Int      @id @default(autoincrement())
  storeId   Int
  store     MiniStore @relation(fields: [storeId], references: [id])
  school    String
  status    String   @default("enabled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, school])
  @@index([school, status])
  @@index([storeId, status])
}

model MiniStoreProductCategory {
  id        Int      @id @default(autoincrement())
  storeId   Int
  store     MiniStore @relation(fields: [storeId], references: [id])
  name      String
  sortOrder Int      @default(0)
  status    String   @default("enabled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  MiniStoreProduct[]

  @@index([storeId, sortOrder])
}

model MiniStoreProduct {
  id           Int      @id @default(autoincrement())
  productKey   String   @unique
  storeId      Int
  store        MiniStore @relation(fields: [storeId], references: [id])
  categoryId   Int?
  category     MiniStoreProductCategory? @relation(fields: [categoryId], references: [id])
  categoryName String   @default("默认分类")
  name         String
  desc         String
  detailTitle  String   @default("")
  detailText   String   @default("")
  detailItems  Json?
  cover        String
  recommended  Boolean  @default(false)
  status       String
  specMode     String
  priceText    String
  stock        Int      @default(0)
  dailyLimit   Int      @default(0)
  defaultSkuKey String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  skus         MiniStoreProductSku[]

  @@index([storeId, sortOrder])
  @@index([categoryId, sortOrder])
}

model MiniStoreProductSku {
  id          Int      @id @default(autoincrement())
  skuKey      String   @unique
  productId   Int
  product     MiniStoreProduct @relation(fields: [productId], references: [id])
  name        String
  priceText   String
  stock       Int      @default(0)
  dailyLimit  Int      @default(0)
  status      String
  isDefault   Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId, sortOrder])
}

model AdminStoreChangeLog {
  id               Int       @id @default(autoincrement())
  storeId          Int
  store            MiniStore @relation(fields: [storeId], references: [id])
  school           String
  module           String
  action           String
  targetType       String
  targetId         String
  operatorId       Int
  operator         AdminUser @relation(fields: [operatorId], references: [id])
  operatorRoleCode String
  operatorScopeType String
  changeMode       String
  summary          String
  beforeData       Json?
  afterData        Json?
  createdAt        DateTime  @default(now())

  @@index([storeId, createdAt])
  @@index([operatorId, createdAt])
  @@index([school, createdAt])
}

model StoreProductApproval {
  id                   Int       @id @default(autoincrement())
  storeId              Int
  store                MiniStore @relation(fields: [storeId], references: [id])
  school               String
  targetType           String
  targetId             String
  action               String
  status               String
  reason               String
  payload              Json
  expectedStoreUpdatedAt DateTime?
  requestedById        Int
  requestedBy          AdminUser @relation("StoreProductApprovalRequester", fields: [requestedById], references: [id])
  reviewedById         Int?
  reviewedBy           AdminUser? @relation("StoreProductApprovalReviewer", fields: [reviewedById], references: [id])
  reviewNote           String?
  reviewedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([storeId, status, createdAt])
  @@index([requestedById, createdAt])
  @@index([school, status])
}

model MerchantAccount {
  id            Int      @id @default(autoincrement())
  miniUserId    Int      @unique
  miniUser      MiniUser @relation(fields: [miniUserId], references: [id])
  storeId       Int      @unique
  store         MiniStore @relation(fields: [storeId], references: [id])
  phone         String   @unique
  name          String
  withdrawChannel String  @default("微信零钱")
  withdrawRealName String?
  withdrawProfileStatus String @default("未建档")
  withdrawBlockedReason String?
  withdrawAgreementAcceptedAt DateTime?
  withdrawOpenidBoundAt DateTime?
  withdrawProfileCompletedAt DateTime?
  password      String?
  status        String
  mustChangePassword Boolean  @default(false)
  activatedAt   DateTime?
  passwordUpdatedAt DateTime?
  initialPasswordSentAt DateTime?
  lastLoginAt   DateTime?
  referrals     MerchantReferral[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MerchantReferral {
  id                Int             @id @default(autoincrement())
  merchantAccountId Int
  merchantAccount   MerchantAccount @relation(fields: [merchantAccountId], references: [id])
  storeId           Int
  userId            Int             @unique
  user              MiniUser        @relation(fields: [userId], references: [id])
  scene             String
  source            String          @default("mini_qr")
  billable          Boolean         @default(true)
  unitPriceCents    Int             @default(100)
  status            String          @default("pending")
  firstLoginAt      DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([merchantAccountId, createdAt])
  @@index([storeId, createdAt])
  @@index([status, createdAt])
  @@index([scene])
}

model MerchantLoginCode {
  id         Int      @id @default(autoincrement())
  phone      String
  code       String
  scene      String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([phone, scene, createdAt])
  @@index([phone, expiresAt])
}

model MiniMessage {
  id             Int               @id @default(autoincrement())
  school         String
  type           String
  category       String
  content        String
  status         String
  receiverUserId Int?
  receiverUser   MiniUser?         @relation("MiniMessageReceiver", fields: [receiverUserId], references: [id])
  targetType     String?
  targetId       String?
  reads          MiniMessageRead[]
  deletes        MiniMessageDelete[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model MiniMessageRead {
  id        Int         @id @default(autoincrement())
  messageId Int
  message   MiniMessage @relation(fields: [messageId], references: [id])
  userId    Int
  user      MiniUser    @relation(fields: [userId], references: [id])
  readAt    DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([messageId, userId])
}

model MiniMessageDelete {
  id        Int         @id @default(autoincrement())
  messageId Int
  message   MiniMessage @relation(fields: [messageId], references: [id])
  userId    Int
  user      MiniUser    @relation(fields: [userId], references: [id])
  deletedAt DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([messageId, userId])
  @@index([userId, deletedAt])
}

model MiniShopApply {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         MiniUser @relation(fields: [userId], references: [id])
  school       String
  storeName    String
  category     String
  contactName  String
  contactPhone String
  description  String
  status       String
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MiniFavorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       MiniUser @relation(fields: [userId], references: [id])
  targetType String
  targetId   String
  school     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, targetType, targetId])
}

model MiniAddress {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         MiniUser @relation(fields: [userId], references: [id])
  school       String
  receiverName String
  phone        String
  detail       String
  tag          String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MiniOrder {
  id              Int       @id @default(autoincrement())
  orderNo         String    @unique
  userId          Int
  user            MiniUser  @relation(fields: [userId], references: [id])
  school          String
  storeDetailId   String
  storeName       String
  productId       String
  skuId           String?
  skuName         String?
  productName     String
  productDesc     String?
  productCover    String?
  unitPrice       Float
  quantity        Int       @default(1)
  amount          Float
  status          String
  payStatus       String
  paymentChannel  String?
  paymentMode     String?
  transactionId   String?
  paymentMeta     Json?
  receiverName    String
  receiverPhone   String
  receiverAddress String
  addressTag      String?
  remark          String?
  paidAt          DateTime?
  canceledAt      DateTime?
  finishedAt      DateTime?
  settlementStatus        String   @default("未结算")
  settlementAmount        Float    @default(0)
  commissionRateSnapshot  Float?
  platformCommissionAmount Float   @default(0)
  merchantIncomeAmount    Float    @default(0)
  settledAt              DateTime?
  profitSharingStatus    String   @default("未分账")
  profitSharingAmount    Float    @default(0)
  profitSharedAt         DateTime?
  refunds         MiniRefundRecord[]
  profitSharingOrders MiniProfitSharingOrder[]
  profitSharingReturnOrders MiniProfitSharingReturnOrder[]
  items           MiniOrderItem[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, status])
  @@index([userId, createdAt])
}

model MiniOrderItem {
  id           Int       @id @default(autoincrement())
  orderId      Int
  order        MiniOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  skuId        String?
  skuName      String?
  productName  String
  productDesc  String?
  productCover String?
  unitPrice    Float
  quantity     Int       @default(1)
  amount       Float
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([orderId])
  @@index([productId])
}

model MiniPostReport {
  id             Int       @id @default(autoincrement())
  reportNo       String    @unique
  postId         Int
  post           MiniPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporterUserId Int
  reporter       MiniUser  @relation("MiniPostReportReporter", fields: [reporterUserId], references: [id])
  school         String
  reason         String
  detail         String?
  status         String
  reviewNote     String?
  reviewerId     Int?
  reviewer       AdminUser? @relation("PostReportReviewer", fields: [reviewerId], references: [id])
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([school, status])
  @@index([postId])
  @@index([reporterUserId])
}

model MiniRefundRecord {
  id         Int       @id @default(autoincrement())
  refundNo   String    @unique
  orderId    Int
  order      MiniOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId     Int
  user       MiniUser  @relation("MiniRefundApplicant", fields: [userId], references: [id])
  school     String
  amount     Float
  reason     String
  status     String
  refundRequestNo String?
  refundChannel   String?
  refundMeta      Json?
  reviewNote String?
  reviewerId Int?
  reviewer   AdminUser? @relation("RefundReviewer", fields: [reviewerId], references: [id])
  applyTime  DateTime  @default(now())
  reviewedAt DateTime?
  refundSuccessAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([school, status])
  @@index([orderId])
  @@index([userId, status])
}

model MiniProfitSharingOrder {
  id              Int       @id @default(autoincrement())
  outOrderNo      String    @unique
  orderId         Int
  order           MiniOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  school          String
  amount          Float
  status          String
  wechatStatus    String?
  receiverType    String
  receiverAccount String
  receiverName    String
  subMchId        String
  transactionId   String?
  responseCode    String?
  failureCode     String?
  failureReason   String?
  requestPayload  Json?
  responsePayload Json?
  returnOrders    MiniProfitSharingReturnOrder[]
  syncAttempts    Int       @default(0)
  lastSyncAt      DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([orderId, status])
  @@index([status, createdAt])
}

model MiniProfitSharingReturnOrder {
  id                    Int                    @id @default(autoincrement())
  outReturnNo           String                 @unique
  orderId               Int
  order                 MiniOrder              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  profitSharingOrderId  Int?
  profitSharingOrder    MiniProfitSharingOrder? @relation(fields: [profitSharingOrderId], references: [id], onDelete: SetNull)
  school                String
  amount                Float
  status                String
  wechatStatus          String?
  description           String?
  subMchId              String
  outOrderNo            String
  transactionId         String?
  responseCode          String?
  failureCode           String?
  failureReason         String?
  requestPayload        Json?
  responsePayload       Json?
  syncAttempts          Int                    @default(0)
  lastSyncAt            DateTime?
  finishedAt            DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@index([orderId, status])
  @@index([status, createdAt])
  @@index([profitSharingOrderId])
}

model MiniWalletAccount {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               MiniUser @relation(fields: [userId], references: [id])
  school             String
  accountName        String
  status             String
  balance            Float    @default(0)
  frozenAmount       Float    @default(0)
  withdrawableAmount Float    @default(0)
  totalIncome        Float    @default(0)
  totalWithdrawn     Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MiniWithdrawRecord {
  id          Int      @id @default(autoincrement())
  withdrawNo  String   @unique
  userId      Int
  user        MiniUser @relation(fields: [userId], references: [id])
  school      String
  accountName String
  amount      Float
  accountType String
  accountNo   String
  status      String
  transferStatus        String?
  transferOutBillNo     String?  @unique
  transferBillNo        String?
  transferFailReason    String?
  transferAppliedAt     DateTime?
  transferSuccessAt     DateTime?
  reviewNote  String?
  applyTime   DateTime @default(now())
  reviewedAt  DateTime?
  transferBills MiniWithdrawTransferBill[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, applyTime])
  @@index([status, transferStatus])
}

model MiniWithdrawTransferBill {
  id               Int                @id @default(autoincrement())
  withdrawRecordId Int
  withdrawRecord   MiniWithdrawRecord @relation(fields: [withdrawRecordId], references: [id], onDelete: Cascade)
  school           String
  userId           Int
  outBillNo        String             @unique
  transferBillNo   String?
  subMchId         String
  openid           String
  amount           Float
  status           String
  wechatStatus     String?
  sceneId          String?
  userName         String?
  failReason       String?
  packageInfo      String?
  requestPayload   Json?
  responsePayload  Json?
  syncAttempts     Int                @default(0)
  lastSyncAt       DateTime?
  acceptedAt       DateTime?
  successAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([withdrawRecordId, status])
  @@index([status, createdAt])
  @@index([userId, status])
}

model UserPublishRecord {
  id        Int      @id @default(autoincrement())
  school    String
  user      String
  type      String
  title     String
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSpec {
  id          Int      @id @default(autoincrement())
  school      String
  storeName   String
  productName String
  specGroup   String
  specValue   String
  price       Float
  stock       Int
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminPostCategory {
  id        Int      @id @default(autoincrement())
  school    String
  name      String
  code      String
  sort      Int      @default(0)
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([school, name])
  @@unique([school, code])
  @@index([school, status])
  @@index([school, sort])
}

model AdminStoreCategory {
  id        Int      @id @default(autoincrement())
  school    String
  name      String
  code      String
  sort      Int      @default(0)
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([school, name])
  @@unique([school, code])
  @@index([school, status])
  @@index([school, sort])
}

model AdminProductCategory {
  id        Int      @id @default(autoincrement())
  school    String
  name      String
  code      String
  sort      Int      @default(0)
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([school, name])
  @@unique([school, code])
  @@index([school, status])
  @@index([school, sort])
}

model AdminMessageTemplate {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  school    String
  channel   String
  status    String
  content   String
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([school, status])
}

model AdminSearchWord {
  id          Int      @id @default(autoincrement())
  school      String
  keyword     String
  searchCount Int      @default(0)
  sort        Int      @default(0)
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([school, status])
}

model AdminHelpArticle {
  id        Int      @id @default(autoincrement())
  category  String
  title     String
  school    String
  status    String
  content   String
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, status])
}

model AdminBannerConfig {
  id        Int      @id @default(autoincrement())
  title     String
  position  String
  school    String
  imageUrl  String?
  linkUrl   String?
  sort      Int      @default(0)
  status    String
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([school, status])
}

model AdminRecommendConfig {
  id         Int      @id @default(autoincrement())
  title      String
  type       String
  school     String
  targetName String?
  targetId   String?
  sort       Int      @default(0)
  status     String
  remark     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([school, status])
}

model AdminSystemConfig {
  id           Int      @id @default(autoincrement())
  sectionKey   String
  sectionTitle String
  configKey    String   @unique
  label        String
  value        String
  valueType    String
  suffix       String?
  sort         Int      @default(0)
  status       String
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sectionKey, sort])
}

model AdminDictType {
  id        Int             @id @default(autoincrement())
  name      String
  code      String          @unique
  status    String
  remark    String?
  sort      Int             @default(0)
  items     AdminDictItem[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model AdminDictItem {
  id        Int           @id @default(autoincrement())
  typeId    Int
  type      AdminDictType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  label     String
  value     String
  sort      Int           @default(0)
  status    String
  remark    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([typeId, sort])
}
