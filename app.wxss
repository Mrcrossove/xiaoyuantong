page {
  background: linear-gradient(180deg, #f8fbff 0%, #eef2f8 100%);
  color: #202534;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 20rpx 24rpx 180rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(53, 88, 163, 0.12);
}

.topbar {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #202534;
}

.topbar-left,
.topbar-right {
  width: 140rpx;
  display: flex;
  align-items: center;
}

.topbar-left {
  justify-content: flex-start;
}

.topbar-right {
  justify-content: flex-end;
  gap: 16rpx;
}

.circle-btn,
.ring-btn,
.back-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 2rpx solid rgba(228, 234, 245, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(36, 55, 96, 0.1);
  position: relative;
}

.circle-btn::before,
.circle-btn::after {
  content: "";
  position: absolute;
  background: #1d2433;
}

.user-btn::before {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  top: 14rpx;
  left: 20rpx;
}

.user-btn::after {
  width: 34rpx;
  height: 18rpx;
  border-radius: 18rpx 18rpx 24rpx 24rpx;
  left: 15rpx;
  bottom: 12rpx;
}

.more-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}

.more-btn view {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #1d2433;
}

.ring-btn::before {
  content: "";
  position: absolute;
  inset: 14rpx;
  border-radius: 50%;
  border: 5rpx solid #1d2433;
}

.back-btn::before,
.back-btn::after {
  content: "";
  position: absolute;
  left: 20rpx;
  width: 20rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #1d2433;
  transform-origin: left center;
}

.back-btn::before {
  top: 25rpx;
  transform: rotate(-45deg);
}

.back-btn::after {
  top: 39rpx;
  transform: rotate(45deg);
}

.post-head {
  display: grid;
  grid-template-columns: 92rpx 1fr auto;
  gap: 20rpx;
  align-items: start;
}

.avatar {
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff8acd, #79adff);
  position: relative;
  overflow: hidden;
}

.avatar::before {
  content: "";
  position: absolute;
  inset: 16rpx 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
}

.avatar::after {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 14rpx;
  height: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx 24rpx 34rpx 34rpx;
}

.author-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #202534;
}

.meta-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.school-name {
  color: #6e84bf;
  font-size: 24rpx;
}

.tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #4f84ff, #2f68e3);
  color: #ffffff;
  font-size: 22rpx;
  line-height: 1;
}

.post-time {
  color: #8e96ab;
  font-size: 22rpx;
  padding-top: 4rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.image-item {
  aspect-ratio: 1 / 1;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.image-item.style-list {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(239, 245, 255, 0.92)), linear-gradient(135deg, #6d95ff, #a2bbff);
}

.image-item.style-list::before {
  content: "";
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #8db1ff;
  box-shadow: 0 0 0 8rpx #d8e5ff;
}

.image-item.style-list::after {
  content: "";
  position: absolute;
  top: 24rpx;
  left: 58rpx;
  width: 70rpx;
  height: 8rpx;
  background: #cad8f2;
  border-radius: 999rpx;
  box-shadow: 0 22rpx 0 #cad8f2, 0 44rpx 0 #cad8f2, 0 66rpx 0 #cad8f2;
}

.image-item.style-cat {
  background: radial-gradient(circle at 52% 42%, #fcfbff 0 46rpx, transparent 47rpx), linear-gradient(180deg, #dbf2ff, #bad4f1);
}

.image-item.style-cat::before,
.image-item.style-cat::after {
  content: "";
  position: absolute;
  top: 28rpx;
  width: 32rpx;
  height: 32rpx;
  background: #fcfbff;
  border-radius: 6rpx 22rpx 0 22rpx;
}

.image-item.style-cat::before {
  left: 48rpx;
  transform: rotate(-32deg);
}

.image-item.style-cat::after {
  right: 48rpx;
  transform: rotate(32deg) scaleX(-1);
}

.image-item.style-cartoon {
  background: radial-gradient(circle at 56% 44%, #ffeef8 0 46rpx, transparent 47rpx), linear-gradient(180deg, #e7d4ff, #f7f3ff);
}

.image-item.style-cartoon::before {
  content: "";
  position: absolute;
  top: 62rpx;
  left: 70rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #664b97;
  box-shadow: 30rpx 0 0 #664b97;
}

.image-item.style-cartoon::after {
  content: "";
  position: absolute;
  left: 72rpx;
  top: 98rpx;
  width: 48rpx;
  height: 24rpx;
  border-radius: 999rpx;
  background: #f89ad0;
}

.image-item.style-device {
  background: linear-gradient(180deg, #e7eefc, #bfd0f4), linear-gradient(135deg, #5275c8, #89a1d9);
}

.image-item.style-device::before {
  content: "";
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  top: 16rpx;
  bottom: 16rpx;
  border-radius: 10rpx;
  background: linear-gradient(180deg, #d1dffb, #7994ca);
  box-shadow: inset 0 0 0 3rpx rgba(255, 255, 255, 0.4);
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(20, 29, 49, 0.38);
  z-index: 90;
}

.tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 12rpx 10rpx 10rpx;
  border-radius: 34rpx;
  border: 2rpx solid rgba(226, 233, 244, 0.96);
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 42rpx rgba(32, 47, 82, 0.13);
  backdrop-filter: blur(18rpx);
  z-index: 20;
}

.tab {
  min-height: 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #9da8bc;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 26rpx;
  transition: color 0.18s ease, background 0.18s ease, transform 0.18s ease;
}

.tab.active {
  color: #245fe0;
  font-weight: 800;
  background: #edf4ff;
  transform: translateY(-2rpx);
}

.tab-icon {
  width: 44rpx;
  height: 40rpx;
  position: relative;
}

.tab-icon.home::before {
  content: "";
  position: absolute;
  left: 7rpx;
  top: 13rpx;
  width: 30rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-top: 0;
  border-radius: 0 0 8rpx 8rpx;
}

.tab-icon.home::after {
  content: "";
  position: absolute;
  left: 12rpx;
  top: 5rpx;
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  border-radius: 5rpx 0 0 0;
  transform: rotate(45deg);
}

.tab.active .tab-icon.home::before {
  background: currentColor;
}

.tab-icon.shop::before {
  content: "";
  position: absolute;
  left: 7rpx;
  right: 7rpx;
  top: 16rpx;
  bottom: 3rpx;
  border: 4rpx solid currentColor;
  border-radius: 7rpx;
  border-top: 0;
}

.tab-icon.shop::after {
  content: "";
  position: absolute;
  left: 6rpx;
  right: 6rpx;
  top: 6rpx;
  height: 15rpx;
  border: 4rpx solid currentColor;
  border-radius: 10rpx 10rpx 4rpx 4rpx;
}

.tab.active .tab-icon.shop::before {
  background: currentColor;
}

.tab.active .tab-icon.shop::after {
  background: rgba(47, 109, 240, 0.2);
}

.tab-icon.message::before {
  content: "";
  position: absolute;
  left: 5rpx;
  top: 7rpx;
  width: 34rpx;
  height: 24rpx;
  border-radius: 13rpx;
  border: 4rpx solid currentColor;
}

.tab-icon.message::after {
  content: "";
  position: absolute;
  left: 15rpx;
  bottom: 3rpx;
  width: 10rpx;
  height: 10rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  background: #ffffff;
  transform: skewX(-18deg) rotate(-10deg);
}

.tab.active .tab-icon.message::before {
  background: currentColor;
}

.tab.active .tab-icon.message::after {
  background: #e7f0ff;
}

.tab-icon.user::before,
.tab-icon.user::after {
  content: "";
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  border: 4rpx solid currentColor;
  box-sizing: border-box;
}

.tab-icon.user::before {
  top: 4rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.tab-icon.user::after {
  bottom: 2rpx;
  width: 34rpx;
  height: 18rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
}

.tab.active .tab-icon.user::before,
.tab.active .tab-icon.user::after {
  background: currentColor;
}
