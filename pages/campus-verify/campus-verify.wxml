<view class="verify-page">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="verify-nav">
    <view class="nav-left">
      <view class="back-btn" bindtap="goBack"></view>
    </view>
    <view class="verify-title">校园认证</view>
    <view class="nav-spacer"></view>
  </view>

  <view class="hero-card">
    <view class="hero-copy">
      <view class="hero-eyebrow">CAMPUS VERIFY</view>
      <view class="hero-title">完成认证后，解锁校园功能</view>
      <view class="hero-desc">认证后可发布帖子、申请开店、参与交易与校内互动。</view>
    </view>
    <view class="hero-mark">
      <view class="mark-ring"></view>
      <view class="mark-check"></view>
    </view>
  </view>

  <view class="status-card">
    <view class="status-main">
      <view class="status-label">当前状态</view>
      <view class="status-value {{verification.verified ? 'success' : ''}}">
        {{verification.verified ? "已认证" : verification.statusText}}
      </view>
    </view>
    <view class="status-note">
      {{verification.verified ? "你的学校信息已同步到首页推荐范围。" : "请填写真实信息，学校必须从标准列表中选择。"}}
    </view>
    <view wx:if="{{verification.reviewNote}}" class="review-note">说明：{{verification.reviewNote}}</view>
  </view>

  <view class="form-card">
    <view class="card-head">
      <view>
        <view class="card-title">认证信息</view>
        <view class="card-subtitle">仅用于校内身份确认，不会公开展示。</view>
      </view>
      <view class="step-badge">1 分钟</view>
    </view>

    <view class="field-block">
      <view class="field-label">姓名 <text class="required">*</text></view>
      <input
        class="field-input"
        value="{{form.name}}"
        placeholder="请输入真实姓名"
        placeholder-class="input-placeholder"
        bindinput="onNameInput"
      />
    </view>

    <view class="field-block">
      <view class="field-label">手机号 <text class="required">*</text></view>
      <input
        class="field-input"
        value="{{form.phone}}"
        type="number"
        maxlength="11"
        placeholder="请输入 11 位手机号"
        placeholder-class="input-placeholder"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="field-block">
      <view class="field-label">学校 <text class="required">*</text></view>
      <view class="school-select" bindtap="openSchoolPicker">
        <view class="school-value {{form.school ? '' : 'empty'}}">
          {{form.school || "搜索并选择学校标准名称"}}
        </view>
        <view class="school-arrow">选择</view>
      </view>
      <view class="field-helper {{schoolMatched ? 'ok' : ''}}">
        {{schoolHelperText}}
      </view>
    </view>
  </view>

  <view class="tips-card">
    <view class="tips-title">为什么有些学校不能认证？</view>
    <view class="tips-line">学校名称需要使用列表里的标准全称，例如“贵州财经大学”。</view>
    <view class="tips-line">直接输入“财大”“师院”这类简称不会通过，请搜索后点击结果。</view>
    <view class="tips-line">如果确实搜不到学校，需要后续把学校补充进学校库。</view>
  </view>

  <view wx:if="{{schoolPickerVisible}}" class="school-picker-mask" bindtap="closeSchoolPicker">
    <view class="school-picker-panel" catchtap="stopTap">
      <view class="picker-handle"></view>
      <view class="school-picker-head">
        <view>
          <view class="school-picker-title">选择学校</view>
          <view class="school-picker-subtitle">输入简称或关键词后，请点击下方标准名称</view>
        </view>
        <view class="school-picker-close" bindtap="closeSchoolPicker">关闭</view>
      </view>
      <view class="school-search-box">
        <view class="search-icon"></view>
        <input
          value="{{schoolKeyword}}"
          placeholder="例如：六盘水、财大、贵州财经"
          placeholder-class="input-placeholder"
          bindinput="onSchoolKeywordInput"
          focus="{{schoolPickerVisible}}"
        />
      </view>
      <scroll-view scroll-y class="school-result-list" enhanced show-scrollbar="{{false}}">
        <view
          wx:for="{{schoolOptions}}"
          wx:key="*this"
          class="school-result-item {{item === form.school ? 'active' : ''}}"
          data-school="{{item}}"
          bindtap="selectSchool"
        >
          <view class="school-name">{{item}}</view>
          <view wx:if="{{item === form.school}}" class="selected-dot"></view>
        </view>
        <view wx:if="{{!schoolOptions.length}}" class="school-result-empty">
          <view class="empty-title">没有找到匹配学校</view>
          <view class="empty-text">请换学校全称、省份或简称搜索；如果仍没有，需要联系平台补充学校库。</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="submit-bar">
    <view class="submit-btn {{submitting ? 'disabled' : ''}}" bindtap="submitVerify">
      {{submitting ? "提交中..." : "提交认证"}}
    </view>
  </view>
</view>
