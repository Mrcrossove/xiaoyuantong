.verify-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #ffffff 0, #f4f5f7 240rpx, #f5f6f8 100%);
  padding-bottom: 160rpx;
}

.verify-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 140rpx 1fr 140rpx;
  align-items: center;
  background: #ffffff;
}

.nav-left,
.nav-spacer {
  display: flex;
  align-items: center;
}

.nav-left {
  justify-content: flex-start;
}

.nav-spacer {
  justify-content: flex-end;
  min-height: 64rpx;
}

.verify-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #202534;
}

.verify-banner {
  margin: 0 24rpx;
  border-radius: 0 0 28rpx 28rpx;
  padding: 40rpx 24rpx 36rpx;
  background: linear-gradient(120deg, #3d8fff, #32b56c);
  display: grid;
  justify-items: center;
  color: #ffffff;
}

.banner-badge {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-icon {
  width: 66rpx;
  height: 66rpx;
  position: relative;
}

.badge-layer {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  border-radius: 12rpx;
  border: 6rpx solid #3ab37b;
  border-top-color: transparent;
  border-left-color: transparent;
  transform-origin: center;
}

.badge-layer.one {
  top: 4rpx;
  width: 44rpx;
  height: 20rpx;
  transform: translateX(-50%) rotate(45deg);
}

.badge-layer.two {
  top: 20rpx;
  width: 54rpx;
  height: 24rpx;
  transform: translateX(-50%) rotate(45deg);
}

.badge-layer.three {
  top: 38rpx;
  width: 62rpx;
  height: 26rpx;
  transform: translateX(-50%) rotate(45deg);
}

.banner-title {
  margin-top: 18rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.banner-status {
  margin-top: 14rpx;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
}

.status-value {
  color: #d6ffe3;
  font-weight: 700;
}

.content-shell {
  padding: 20rpx 16rpx 0;
}

.info-card,
.form-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 18rpx 40rpx rgba(49, 71, 111, 0.08);
  padding: 24rpx;
}

.card-title,
.promise-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2a3040;
}

.card-text {
  margin-top: 14rpx;
  color: #7c8598;
  font-size: 24rpx;
  line-height: 1.7;
}

.divider {
  margin: 20rpx 0;
  height: 2rpx;
  background: #edf1f5;
}

.field-block + .field-block {
  margin-top: 24rpx;
}

.field-label {
  color: #2d3446;
  font-size: 28rpx;
  font-weight: 700;
}

.required {
  color: #ff6b6b;
}

.field-input,
.upload-disabled {
  margin-top: 14rpx;
  min-height: 88rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #f8f8fa;
  border: 2rpx solid #ebedf2;
  display: flex;
  align-items: center;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #202534;
}

.school-select-row {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: 1fr 128rpx;
  gap: 14rpx;
  align-items: center;
}

.school-select-row .field-input {
  margin-top: 0;
}

.school-input {
  width: 100%;
}

.school-select-btn {
  height: 88rpx;
  border-radius: 18rpx;
  background: #202534;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-placeholder {
  color: #b2b8c6;
}

.upload-disabled {
  color: #b2b8c6;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 2rpx solid #edf1f5;
}

.submit-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: linear-gradient(120deg, #3d8fff, #32b56c);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.school-picker-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  background: rgba(22, 27, 38, 0.46);
  display: flex;
  align-items: flex-end;
}

.school-picker-panel {
  width: 100%;
  max-height: 78vh;
  padding: 26rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.school-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-picker-title {
  color: #202534;
  font-size: 32rpx;
  font-weight: 800;
}

.school-picker-close {
  color: #778197;
  font-size: 26rpx;
}

.school-search-box {
  margin-top: 22rpx;
  height: 84rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #f4f6fa;
  display: flex;
  align-items: center;
}

.school-search-box input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #202534;
}

.school-result-list {
  margin-top: 18rpx;
  max-height: 52vh;
}

.school-result-item {
  min-height: 84rpx;
  padding: 0 6rpx;
  border-bottom: 2rpx solid #f2f4f8;
  color: #2d3446;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.school-result-item.active {
  color: #2f68e3;
  font-weight: 800;
}

.school-result-empty {
  padding: 44rpx 0;
  color: #9aa4b7;
  font-size: 26rpx;
  text-align: center;
}
