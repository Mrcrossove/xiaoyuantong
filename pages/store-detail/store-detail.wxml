<view class="detail-page" style="padding-top: {{statusBarHeight}}px;" wx:if="{{detail}}">
  <view class="detail-nav" style="padding-right: {{navRightSafeRpx}}rpx;">
    <view class="back-btn" bindtap="goBack"></view>
    <view class="detail-title">{{detail.title || '店铺主页'}}</view>
    <view class="detail-actions">
      <view class="action-chip" bindtap="toggleStoreFavorite">{{favorite ? '已收藏' : '收藏'}}</view>
    </view>
  </view>

  <scroll-view class="detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
    <swiper class="hero-swiper" indicator-dots circular autoplay>
      <swiper-item wx:for="{{detail.banners}}" wx:key="value">
        <view wx:if="{{item.mode === 'class'}}" class="hero-slide cover-{{item.value}}"></view>
        <image wx:else class="hero-slide hero-image" src="{{item.value}}" mode="aspectFill"></image>
      </swiper-item>
    </swiper>

    <view class="store-info card">
      <view class="detail-school">{{selectedSchool}}</view>
      <view class="info-head">
        <view wx:if="{{detail.coverMode === 'class'}}" class="info-cover cover-{{detail.cover}}"></view>
        <image wx:else class="info-cover hero-image" src="{{detail.cover || (detail.banners[0] && detail.banners[0].value)}}" mode="aspectFill"></image>
        <view class="info-meta">
          <view class="store-name">{{detail.storeName}}</view>
          <view class="store-notice">{{detail.notice}}</view>
          <view class="store-phone">联系电话：{{detail.phone || '暂无'}}</view>
        </view>
      </view>

      <view class="address-row {{detail.latitude && detail.longitude ? 'can-navigate' : ''}}" bindtap="openStoreLocation">
        <view class="address-icon"></view>
        <view class="address-content">
          <view class="address-title-row">
            <text class="address-label">店铺地址</text>
            <text wx:if="{{detail.latitude && detail.longitude}}" class="address-hint">点击导航</text>
          </view>
          <view class="address-text">{{detail.address || '暂无地址'}}</view>
        </view>
        <view wx:if="{{detail.latitude && detail.longitude}}" class="address-action">
          <text>导航</text>
          <view class="address-arrow"></view>
        </view>
      </view>
    </view>

    <view class="goods-panel card">
      <view class="goods-tabs">
        <view class="goods-tab {{activeTab === 'goods' ? 'active' : ''}}" data-key="goods" bindtap="switchTab">
          商品 {{detail.products.length}}
        </view>
        <view class="goods-tab {{activeTab === 'intro' ? 'active' : ''}}" data-key="intro" bindtap="switchTab">
          店铺说明
        </view>
      </view>

      <view wx:if="{{activeTab === 'goods'}}" class="goods-list">
        <view wx:if="{{detail.products.length}}" class="goods-menu-layout {{!hasMultipleProductSections ? 'single-section' : ''}}">
          <scroll-view wx:if="{{hasMultipleProductSections}}" scroll-y class="goods-category-nav" enhanced show-scrollbar="{{false}}">
            <view class="goods-category-item {{activeProductCategoryId === item.id ? 'active' : ''}}" wx:for="{{productSections}}" wx:key="id" data-id="{{item.id}}" bindtap="switchProductCategory">
              <view class="goods-category-name">{{item.name}}</view>
              <view class="goods-category-count">{{item.productCount}}</view>
            </view>
          </scroll-view>
          <scroll-view scroll-y class="goods-section-scroll" enhanced show-scrollbar="{{false}}">
            <view class="goods-section-content">
              <view class="goods-tip">点击商品卡片查看详情、参数和购买须知。</view>
              <view class="goods-section-title">{{activeProductCategoryName}}</view>
              <view class="goods-card {{selectedProductId == item.id ? 'active' : ''}}" wx:for="{{displayedProducts}}" wx:key="id" data-id="{{item.id}}" bindtap="openProductDetail">
                <view wx:if="{{item.coverMode === 'class'}}" class="goods-cover cover-{{item.cover}}"></view>
                <image wx:else class="goods-cover hero-image" src="{{item.cover}}" mode="aspectFill"></image>
                <view class="goods-body">
                  <view class="goods-title-row">
                    <view class="goods-name">{{item.name}}</view>
                    <text class="goods-selected">查看详情</text>
                  </view>
                  <view class="goods-desc">{{item.desc}}</view>
                  <view class="goods-meta-row">
                    <text wx:if="{{item.recommended}}" class="goods-tag highlight">推荐商品</text>
                    <text class="goods-tag">库存 {{item.stock || 0}}</text>
                    <text wx:if="{{item.dailyLimit > 0}}" class="goods-tag">每日限购 {{item.dailyLimit}}</text>
                  </view>
                  <view class="goods-purchase-row">
                    <view class="goods-price">{{item.price}}</view>
                    <view class="goods-cart-control" catchtap="stopTap">
                      <block wx:if="{{cartQuantityMap[item.id]}}">
                        <view class="goods-cart-minus" data-id="{{item.id}}" catchtap="decreaseCartItem">-</view>
                        <view class="goods-cart-count">{{cartQuantityMap[item.id]}}</view>
                      </block>
                      <view class="goods-cart-plus" data-id="{{item.id}}" catchtap="addCartItem">+</view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </scroll-view>
        </view>
        <view wx:else class="goods-empty">
          <view class="goods-empty-title">商家正在上架商品</view>
          <view class="goods-empty-desc">当前店铺还没有可购买商品，请稍后再来，或联系商家确认上架时间。</view>
        </view>
      </view>

      <view wx:else class="intro-block">
        <view class="intro-title">{{detail.storeName}}</view>
        <view class="intro-text">{{detail.notice || '暂无店铺说明'}}</view>
        <view class="intro-text">{{detail.address || '暂无店铺地址'}}</view>
      </view>
    </view>
  </scroll-view>

  <view class="checkout-bar {{!cartCount ? 'disabled' : ''}}" wx:if="{{detail.products.length}}">
    <view class="cart-icon"></view>
    <view class="checkout-meta">
      <view class="checkout-amount">合计：{{cartAmountText}}</view>
      <view class="checkout-count">已选 {{cartCount}} 件商品</view>
    </view>
    <view class="checkout-btn" bindtap="openConfirmModal">{{submittingOrder ? '提交中' : '去结算'}}</view>
  </view>

  <view wx:if="{{confirmVisible}}" class="confirm-mask" bindtap="closeConfirmModal"></view>
  <view wx:if="{{confirmVisible}}" class="confirm-modal">
    <view class="confirm-title">确认订单</view>

    <view class="confirm-section">
      <view class="confirm-label">商品信息</view>
      <view class="confirm-item" wx:for="{{cartItems}}" wx:key="key">
        <view>
          <view class="confirm-value">{{item.productName}}</view>
          <view class="confirm-subvalue">{{item.skuName || '默认规格'}} x {{item.quantity}}</view>
        </view>
        <view class="confirm-item-amount">{{item.amountText}}</view>
      </view>
      <view class="confirm-total">共 {{cartCount}} 件，合计 {{cartAmountText}}</view>
    </view>

    <view class="confirm-section">
      <view class="confirm-row">
        <view class="confirm-label">收货地址</view>
        <view class="confirm-link" bindtap="goManageAddress">管理地址</view>
      </view>
      <view class="confirm-value">{{addressSummary}}</view>
    </view>

    <view class="confirm-section">
      <view class="confirm-label">店铺信息</view>
      <view class="confirm-value">{{detail.storeName}}</view>
      <view class="confirm-subvalue">{{detail.address}}</view>
    </view>

    <view class="confirm-actions">
      <view class="confirm-btn ghost" bindtap="closeConfirmModal">取消</view>
      <view class="confirm-btn" bindtap="confirmCheckout">{{submittingOrder ? '提交中' : '确认下单'}}</view>
    </view>
  </view>
</view>

<view wx:else class="detail-empty">
  <view class="detail-empty-title">店铺加载失败</view>
  <view class="detail-empty-desc">请返回重试，或稍后再进入该店铺。</view>
</view>
