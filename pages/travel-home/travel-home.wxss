.travel-page { min-height: 100vh; padding: 0 28rpx 40rpx; background: #f5f7fb; box-sizing: border-box; }
.nav { height: 88rpx; display: flex; align-items: center; justify-content: space-between; }
.back { width: 52rpx; height: 52rpx; border-radius: 50%; background: #fff; position: relative; }
.back::after { content: ""; position: absolute; left: 22rpx; top: 16rpx; width: 16rpx; height: 16rpx; border-left: 4rpx solid #1f2937; border-bottom: 4rpx solid #1f2937; transform: rotate(45deg); }
.title { font-size: 32rpx; font-weight: 800; color: #111827; }
.my { font-size: 26rpx; color: #0f766e; font-weight: 700; }
.hero { padding: 34rpx; border-radius: 28rpx; color: #fff; background: linear-gradient(135deg, #172554, #0f766e); }
.hero-tag { display: inline-flex; padding: 8rpx 16rpx; border-radius: 999rpx; background: rgba(255,255,255,.18); font-size: 22rpx; }
.hero-title { margin-top: 18rpx; font-size: 42rpx; font-weight: 900; }
.hero-desc { margin-top: 10rpx; font-size: 25rpx; color: rgba(255,255,255,.84); line-height: 1.6; }
.empty { margin-top: 24rpx; padding: 40rpx; border-radius: 24rpx; background: #fff; color: #6b7280; text-align: center; }
.route-card { margin-top: 24rpx; border-radius: 28rpx; background: #fff; overflow: hidden; box-shadow: 0 16rpx 40rpx rgba(15,23,42,.08); }
.cover { width: 100%; height: 260rpx; display: block; background: linear-gradient(135deg, #bae6fd, #bbf7d0); }
.route-body { padding: 24rpx; }
.route-title { font-size: 32rpx; font-weight: 800; color: #111827; }
.route-meta, .route-date { margin-top: 8rpx; color: #667085; font-size: 24rpx; }
.progress { margin-top: 18rpx; }
.progress-head { display: flex; justify-content: space-between; color: #0f766e; font-size: 24rpx; font-weight: 700; }
.progress-track { margin-top: 12rpx; height: 14rpx; border-radius: 999rpx; background: #e5e7eb; overflow: hidden; }
.progress-bar { height: 100%; border-radius: 999rpx; background: linear-gradient(90deg, #14b8a6, #f59e0b); }
.highlights { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 16rpx; }
.highlights text { padding: 8rpx 12rpx; border-radius: 999rpx; background: #ecfdf5; color: #047857; font-size: 22rpx; }
