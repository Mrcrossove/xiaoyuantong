.about-page {
  min-height: 100vh;
  background: #f5f7fb;
}

.about-nav {
  height: 88rpx;
  padding: 0 24rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
}

.about-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}

.nav-space {
  width: 88rpx;
}

.hero-card,
.section-card {
  margin: 20rpx 16rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(53, 88, 163, 0.08);
  padding: 28rpx 24rpx;
}

.hero-card {
  display: grid;
  justify-items: center;
  text-align: center;
}

.logo-badge {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #3f83ff, #35b876);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 800;
}

.app-name {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 800;
  color: #202534;
}

.app-version {
  margin-top: 10rpx;
  color: #7f8aa0;
  font-size: 24rpx;
}

.app-intro,
.section-content {
  margin-top: 14rpx;
  color: #68758d;
  font-size: 24rpx;
  line-height: 1.8;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #202534;
}
