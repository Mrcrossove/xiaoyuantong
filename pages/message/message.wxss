.message-page {
  min-height: 100vh;
  padding-left: 0;
  padding-right: 0;
  padding-bottom: 160rpx;
  background: #f5f5f6;
}

.message-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
}

.message-nav-spacer {
  width: 140rpx;
}

.message-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #202534;
}

.message-nav-action {
  min-width: 140rpx;
  text-align: right;
  color: #3f83ff;
  font-size: 24rpx;
  font-weight: 700;
}

.message-tabs {
  height: 82rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  align-items: end;
  background: #ffffff;
  border-bottom: 2rpx solid #f0f2f5;
}

.message-school {
  padding: 18rpx 24rpx 8rpx;
  background: #ffffff;
  color: #4a83ff;
  font-size: 24rpx;
  font-weight: 700;
}

.message-tab {
  height: 100%;
  display: grid;
  justify-items: center;
  align-content: center;
  color: #80889b;
  font-size: 28rpx;
  row-gap: 10rpx;
  position: relative;
}

.unread-dot {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff5f5f;
  color: #ffffff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: absolute;
  top: 10rpx;
  right: 78rpx;
}

.message-tab.active {
  color: #3f83ff;
}

.message-tab-line {
  width: 42rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: transparent;
}

.message-tab.active .message-tab-line {
  background: #3f83ff;
}

.message-panel {
  min-height: calc(100vh - 88rpx - 82rpx - 160rpx - env(safe-area-inset-top));
  background: #ffffff;
  padding-bottom: 24rpx;
}

.message-entry {
  min-height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-top: 2rpx solid #f1f3f7;
  color: #2a3040;
  font-size: 34rpx;
}

.entry-icon {
  width: 28rpx;
  height: 28rpx;
  position: relative;
}

.entry-icon.horn::before {
  content: "";
  position: absolute;
  left: 0;
  top: 6rpx;
  width: 18rpx;
  height: 14rpx;
  background: #4a86ff;
  clip-path: polygon(0 40%, 55% 40%, 100% 0, 100% 100%, 55% 60%, 0 60%);
}

.entry-icon.horn::after {
  content: "";
  position: absolute;
  right: 2rpx;
  top: 3rpx;
  width: 4rpx;
  height: 22rpx;
  background: #4a86ff;
  border-radius: 999rpx;
}

.entry-icon.heart::before {
  content: "";
  position: absolute;
  inset: 0;
  background: #4a86ff;
  clip-path: polygon(50% 100%, 0 45%, 16% 16%, 38% 16%, 50% 30%, 62% 16%, 84% 16%, 100% 45%);
}

.empty-text {
  padding-top: 130rpx;
  text-align: center;
  color: #c0c4cd;
  font-size: 32rpx;
}

.message-card {
  margin: 16rpx 24rpx 0;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f7f9fd;
}

.message-card.unread {
  background: #edf4ff;
}

.message-card.read {
  opacity: 0.8;
}

.message-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.message-card-category {
  color: #2a3040;
  font-size: 28rpx;
  font-weight: 700;
}

.message-card-time {
  color: #9aa3b2;
  font-size: 22rpx;
}

.message-meta-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.message-badge {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #ffefef;
  color: #e25b5b;
  font-size: 18rpx;
  font-weight: 700;
}

.message-card-content {
  color: #5c6780;
  font-size: 26rpx;
  line-height: 1.7;
}

.message-order-tag {
  margin-bottom: 12rpx;
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8fff0;
  color: #29a36a;
  font-size: 20rpx;
  font-weight: 700;
}

.message-action-line {
  margin-top: 14rpx;
  color: #2f68e3;
  font-size: 22rpx;
  font-weight: 700;
}
