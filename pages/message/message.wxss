.message-page {
  min-height: 100vh;
  padding-bottom: 160rpx;
  background:
    radial-gradient(circle at 18% 0%, rgba(76, 132, 255, 0.16), transparent 34%),
    linear-gradient(180deg, #f7faff 0%, #f4f6fb 42%, #f7f8fb 100%);
}

.message-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 96rpx 1fr 96rpx;
  align-items: center;
  box-sizing: border-box;
}

.message-nav-spacer {
  width: 96rpx;
}

.message-title {
  text-align: center;
  font-size: 36rpx;
  font-weight: 800;
  color: #182235;
}

.message-hero {
  margin: 10rpx 24rpx 18rpx;
  padding: 26rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #2f68e3, #43b58f);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  box-shadow: 0 20rpx 46rpx rgba(47, 104, 227, 0.18);
}

.message-school {
  font-size: 30rpx;
  font-weight: 800;
}

.message-hero-desc {
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 23rpx;
}

.message-read-btn {
  flex: 0 0 auto;
  min-width: 132rpx;
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #245fca;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.message-tabs {
  margin: 0 24rpx 18rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  box-shadow: 0 10rpx 30rpx rgba(37, 52, 91, 0.06);
}

.message-tab {
  height: 72rpx;
  border-radius: 18rpx;
  color: #72809a;
  font-size: 27rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  position: relative;
}

.message-tab.active {
  background: #edf4ff;
  color: #2f68e3;
}

.unread-dot {
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff5f5f;
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.message-panel {
  margin: 0 24rpx;
  padding: 20rpx 0 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 34rpx rgba(37, 52, 91, 0.06);
}

.message-entry {
  min-height: 62rpx;
  padding: 0 24rpx 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #202a3d;
  font-size: 30rpx;
  font-weight: 800;
}

.entry-icon {
  width: 30rpx;
  height: 30rpx;
  position: relative;
}

.entry-icon.horn::before {
  content: "";
  position: absolute;
  left: 0;
  top: 7rpx;
  width: 19rpx;
  height: 14rpx;
  background: #4a86ff;
  clip-path: polygon(0 40%, 55% 40%, 100% 0, 100% 100%, 55% 60%, 0 60%);
}

.entry-icon.horn::after {
  content: "";
  position: absolute;
  right: 3rpx;
  top: 4rpx;
  width: 4rpx;
  height: 22rpx;
  background: #4a86ff;
  border-radius: 999rpx;
}

.entry-icon.heart::before {
  content: "";
  position: absolute;
  inset: 0;
  background: #4a86ff;
  clip-path: polygon(50% 100%, 0 45%, 16% 16%, 38% 16%, 50% 30%, 62% 16%, 84% 16%, 100% 45%);
}

.empty-text {
  padding: 110rpx 36rpx;
  text-align: center;
  color: #9aa5b8;
  font-size: 28rpx;
}

.message-card {
  margin: 16rpx 20rpx 0;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f8fafd;
  border: 2rpx solid transparent;
}

.message-card.unread {
  background: #eef5ff;
  border-color: #d9e8ff;
}

.message-card.read {
  opacity: 0.82;
}

.message-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.message-card-category {
  color: #202a3d;
  font-size: 28rpx;
  font-weight: 800;
}

.message-card-time {
  color: #9aa3b2;
  font-size: 22rpx;
}

.message-meta-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.message-badge {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #ffefef;
  color: #e25b5b;
  font-size: 18rpx;
  font-weight: 800;
}

.message-card-content {
  color: #5c6780;
  font-size: 26rpx;
  line-height: 1.7;
}

.message-order-tag {
  margin-bottom: 12rpx;
  display: inline-flex;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e8fff0;
  color: #29a36a;
  font-size: 20rpx;
  font-weight: 800;
}

.message-action-line {
  margin-top: 14rpx;
  color: #2f68e3;
  font-size: 22rpx;
  font-weight: 800;
}
