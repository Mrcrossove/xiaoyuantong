<view class="page-shell detail-shell">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="topbar detail-topbar">
    <view class="topbar-left">
      <view class="back-btn" bindtap="goBack"></view>
    </view>
    <view class="topbar-title detail-title">帖子详情</view>
    <view class="topbar-right"></view>
  </view>

  <block wx:if="{{post}}">
    <view class="detail-card card">
      <view class="post-head">
        <view class="avatar"></view>
        <view>
          <view class="author-name">{{post.author}}</view>
          <view class="meta-row">
            <text class="school-name">{{post.school}}</text>
            <text class="tag">{{post.category}}</text>
          </view>
        </view>
        <text class="post-time">{{post.time}}</text>
      </view>

      <view class="detail-post-title">{{post.title}}</view>
      <view class="detail-post-text">{{post.content}}</view>

      <view class="stats-row">
        <text>浏览 {{post.viewCount}}</text>
        <text>点赞 {{post.likeCount}}</text>
        <text>评论 {{post.commentCount}}</text>
      </view>

      <view class="image-grid detail-grid">
        <view class="image-item {{item}}" wx:for="{{post.images}}" wx:key="*this"></view>
      </view>

      <view class="contact-trigger" bindtap="showContact">点击获取联系方式</view>

      <view class="detail-actions">
        <view class="detail-action like-action {{post.liked ? 'active' : ''}}" bindtap="handleToggleLike">
          <view class="action-icon-wrap">
            <view class="icon like"></view>
          </view>
          <text>点赞 {{post.likeCount}}</text>
        </view>
        <view class="detail-action comment-action" bindtap="focusCommentInput">
          <view class="action-icon-wrap">
            <view class="icon comment"></view>
          </view>
          <text>评论 {{post.commentCount}}</text>
        </view>
        <view class="detail-action favorite-action {{favorite ? 'active' : ''}}" bindtap="togglePostFavorite">
          <view class="action-icon-wrap">
            <view class="icon star"></view>
          </view>
          <text>{{favorite ? "已收藏" : "收藏"}}</text>
        </view>
        <button class="detail-action share-action share-button" open-type="share">
          <view class="action-icon-wrap">
            <view class="icon share"></view>
          </view>
          <text>分享</text>
        </button>
      </view>
    </view>

    <view class="comment-section card">
      <view class="comment-title">评论区 ({{post.commentCount}})</view>

      <view class="comment-list" wx:if="{{post.comments.length}}">
        <view class="comment-item" wx:for="{{post.comments}}" wx:key="id">
          <view class="comment-author">{{item.author}}</view>
          <view class="comment-content">{{item.content}}</view>
          <view class="comment-time">{{item.time}}</view>
        </view>
      </view>

      <view class="comment-empty" wx:else>
        <view class="comment-illustration">
          <view></view>
          <view></view>
          <view></view>
        </view>
        <text>暂无评论，快来抢沙发吧</text>
      </view>
    </view>

    <view class="detail-input-bar">
      <input value="{{commentInput}}" bindinput="onCommentInput" placeholder="说点什么..." placeholder-class="placeholder" />
      <view class="send-btn active" bindtap="submitComment">{{sendingComment ? "发送中" : "发送"}}</view>
    </view>

    <view wx:if="{{contactVisible}}" class="overlay" bindtap="hideContact"></view>
    <view wx:if="{{contactVisible}}" class="contact-modal">
      <view class="contact-card">
        <view class="close-modal" bindtap="hideContact"></view>
        <view class="contact-label">联系方式</view>
        <view class="contact-title">联系帖主</view>
        <view class="contact-list">
          <view class="contact-item" wx:for="{{post.contact}}" wx:key="label">
            <text class="contact-item-label">{{item.label}}</text>
            <text class="contact-item-value">{{item.value}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view wx:else class="detail-empty card">
    <view class="detail-empty-title">{{loadErrorText || "帖子不存在或已下架"}}</view>
    <view class="detail-empty-desc">{{loadErrorText ? "请稍后重试，恢复后会自动展示详情内容" : "返回上一页继续浏览其他帖子"}}</view>
  </view>
</view>
