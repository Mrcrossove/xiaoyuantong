<view class="publish-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="publish-nav">
    <view class="back-touch" bindtap="goBack">
      <view class="back-arrow"></view>
    </view>
    <view class="publish-title">{{pageTitle}}</view>
    <view class="publish-action {{publishing ? 'loading' : 'active'}}" bindtap="submitPublish">
      {{publishing ? "发布中" : "发布"}}
    </view>
  </view>

  <scroll-view scroll-y class="publish-scroll">
    <view class="form-card">
      <view class="field-label">分类</view>
      <view class="field-value chosen">{{category}}</view>
    </view>

    <view class="form-card">
      <view class="field-label">标题</view>
      <input
        class="field-input"
        value="{{title}}"
        data-field="title"
        bindinput="onInputChange"
        placeholder="请输入标题，最多 30 个字"
        maxlength="30"
        placeholder-class="placeholder"
      />
      <view class="field-count">{{title.length}}/30</view>
    </view>

    <view class="form-card">
      <view class="field-label">详细描述</view>
      <textarea
        class="field-textarea"
        value="{{content}}"
        data-field="content"
        bindinput="onInputChange"
        placeholder="详细描述你要发布的内容"
        maxlength="500"
        placeholder-class="placeholder"
      ></textarea>
      <view class="field-count">{{content.length}}/500</view>
    </view>

    <view class="form-card">
      <view class="field-label">图片</view>
      <view class="upload-grid">
        <view class="image-item" wx:for="{{imageFiles}}" wx:key="localPath">
          <image class="image-preview" src="{{item.url || item.localPath}}" mode="aspectFill"></image>
          <view class="image-mask" wx:if="{{item.uploading}}">上传中</view>
          <view class="image-remove" data-index="{{index}}" bindtap="removeImage">删除</view>
        </view>
        <view class="upload-box" wx:if="{{imageFiles.length < 9}}" bindtap="chooseImages">
          <view class="upload-plus"></view>
          <view class="upload-text">添加图片</view>
        </view>
      </view>
      <view class="field-tip">最多上传 9 张图片</view>
    </view>

    <view class="form-card">
      <view class="field-label">联系方式（选填）</view>
      <view class="contact-row">
        <view class="contact-name">手机</view>
        <input
          class="contact-input"
          value="{{phone}}"
          data-field="phone"
          bindinput="onInputChange"
          placeholder="请输入手机号"
          placeholder-class="placeholder"
        />
      </view>
      <view class="contact-row">
        <view class="contact-name">QQ</view>
        <input
          class="contact-input"
          value="{{qq}}"
          data-field="qq"
          bindinput="onInputChange"
          placeholder="请输入 QQ 号"
          placeholder-class="placeholder"
        />
      </view>
      <view class="contact-row">
        <view class="contact-name">微信</view>
        <input
          class="contact-input"
          value="{{wechat}}"
          data-field="wechat"
          bindinput="onInputChange"
          placeholder="请输入微信号"
          placeholder-class="placeholder"
        />
      </view>
      <view class="contact-tip">如需联系，可填写手机号、QQ 或微信。</view>
    </view>

    <view class="form-card">
      <view class="field-label">发布设置</view>
      <view class="switch-row">
        <text>匿名发布</text>
        <switch color="#2f68e3" checked="{{anonymous}}" data-field="anonymous" bindchange="onSwitchChange" />
      </view>
      <view class="switch-row">
        <text>仅当前高校可见</text>
        <switch color="#2f68e3" checked="{{onlyCampus}}" data-field="onlyCampus" bindchange="onSwitchChange" />
      </view>
    </view>
  </scroll-view>
</view>
