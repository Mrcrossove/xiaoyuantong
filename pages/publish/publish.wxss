.publish-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 156rpx;
}

.back-touch {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid #5d6373;
  border-bottom: 4rpx solid #5d6373;
  transform: rotate(45deg);
}

.publish-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 72rpx 1fr 72rpx;
  align-items: center;
  background: #ffffff;
  border-bottom: 2rpx solid #eef1f6;
}

.publish-title {
  text-align: center;
  color: #2f68e3;
  font-size: 32rpx;
  font-weight: 700;
}

.nav-space {
  width: 72rpx;
  height: 72rpx;
}

.publish-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 2rpx solid #edf1f5;
  z-index: 20;
}

.publish-bottom-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: #f4f7fb;
  border: 2rpx solid #e5ebf5;
  color: #a3abbb;
  font-size: 30rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-bottom-btn.active {
  background: #2563eb;
  border-color: #2563eb;
  color: #ffffff;
  box-shadow: 0 18rpx 34rpx rgba(37, 99, 235, 0.24);
}

.publish-bottom-btn.loading {
  background: #dce6f8;
  color: #5c77b4;
}

.publish-scroll {
  height: calc(100vh - 88rpx - env(safe-area-inset-top));
  padding: 18rpx 16rpx 180rpx;
  box-sizing: border-box;
}

.form-card {
  background: #ffffff;
  border-radius: 8rpx;
  padding: 22rpx 18rpx;
  margin-bottom: 18rpx;
  position: relative;
}

.publish-step-card {
  margin-bottom: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 28rpx rgba(59, 80, 122, 0.08);
}

.step-item {
  display: grid;
  justify-items: center;
  gap: 8rpx;
  color: #a1aabb;
  font-size: 22rpx;
}

.step-item.active,
.step-item.done {
  color: #2f68e3;
  font-weight: 700;
}

.step-dot {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #edf1f7;
  display: flex;
  align-items: center;
  justify-content: center;
  color: inherit;
  font-size: 22rpx;
  font-weight: 800;
}

.step-item.active .step-dot,
.step-item.done .step-dot {
  background: #eaf1ff;
}

.step-line {
  flex: 1;
  height: 2rpx;
  margin: 0 16rpx 30rpx;
  background: #e8edf5;
}

.field-label {
  color: #2f3340;
  font-size: 24rpx;
  margin-bottom: 18rpx;
}

.field-value {
  min-height: 42rpx;
  color: #9ea5b4;
  font-size: 26rpx;
}

.field-value.chosen {
  color: #202534;
}

.field-input,
.contact-input {
  height: 48rpx;
  font-size: 26rpx;
}

.field-textarea {
  width: 100%;
  min-height: 180rpx;
  font-size: 26rpx;
  line-height: 1.7;
}

.placeholder {
  color: #b4bbca;
}

.field-count {
  text-align: right;
  color: #c0c6d2;
  font-size: 22rpx;
}

.upload-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  width: 144rpx;
  height: 144rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
  background: #f2f5fb;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-mask {
  position: absolute;
  inset: 0;
  background: rgba(27, 34, 53, 0.45);
  color: #ffffff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-remove {
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 18rpx;
}

.upload-box {
  width: 144rpx;
  height: 144rpx;
  border: 2rpx solid #eef1f6;
  border-radius: 16rpx;
  background: #fafbfe;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.upload-plus {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #b8becb;
  position: relative;
}

.upload-plus::before,
.upload-plus::after {
  content: "";
  position: absolute;
  background: #ffffff;
  border-radius: 999rpx;
}

.upload-plus::before {
  width: 22rpx;
  height: 4rpx;
  left: 11rpx;
  top: 20rpx;
}

.upload-plus::after {
  width: 4rpx;
  height: 22rpx;
  left: 20rpx;
  top: 11rpx;
}

.upload-text {
  color: #a8afbf;
  font-size: 20rpx;
}

.field-tip,
.contact-tip {
  margin-top: 12rpx;
  color: #c0c6d2;
  font-size: 20rpx;
}

.school-readonly-row {
  min-height: 44rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.school-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #36a86e;
  box-shadow: 0 0 0 8rpx rgba(54, 168, 110, 0.12);
}

.location-row {
  min-height: 42rpx;
  display: flex;
  align-items: center;
}

.location-pin {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50% 50% 50% 0;
  background: #4c86ff;
  transform: rotate(-45deg);
  position: relative;
}

.location-pin::after {
  content: "";
  position: absolute;
  inset: 5rpx;
  border-radius: 50%;
  background: #ffffff;
}

.contact-row {
  min-height: 60rpx;
  display: grid;
  grid-template-columns: 80rpx 1fr;
  gap: 18rpx;
  align-items: center;
  border-bottom: 2rpx solid #f4f6fa;
}

.contact-row:last-of-type {
  border-bottom: 0;
}

.contact-name {
  color: #2f3340;
  font-size: 24rpx;
}

.switch-row {
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #2f3340;
  font-size: 26rpx;
}
