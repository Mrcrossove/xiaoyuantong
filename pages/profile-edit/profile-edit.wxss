.edit-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f9fd 0%, #ffffff 58%);
  padding: 0 40rpx;
  box-sizing: border-box;
}

.edit-nav {
  height: 96rpx;
  display: grid;
  grid-template-columns: 96rpx 1fr 96rpx;
  align-items: center;
}

.back-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 2rpx solid rgba(228, 234, 245, 0.92);
  box-shadow: 0 12rpx 28rpx rgba(36, 55, 96, 0.1);
  position: relative;
  margin-left: 18rpx;
}

.edit-nav .back-btn::before,
.edit-nav .back-btn::after {
  display: none;
}

.back-icon {
  position: absolute;
  left: 23rpx;
  top: 21rpx;
  width: 22rpx;
  height: 22rpx;
  border-left: 6rpx solid #1d2433;
  border-bottom: 6rpx solid #1d2433;
  border-radius: 2rpx;
  transform: rotate(45deg);
  box-sizing: border-box;
}

.back-line {
  position: absolute;
  left: 24rpx;
  top: 32rpx;
  width: 28rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: #1d2433;
}

.edit-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 800;
  color: #202534;
}

.brand-block {
  padding: 52rpx 0 78rpx;
  display: grid;
  justify-items: center;
}

.brand-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 18rpx 40rpx rgba(53, 123, 201, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-logo-image {
  width: 104rpx;
  height: 104rpx;
  display: block;
}

.brand-title {
  margin-top: 42rpx;
  color: #202534;
  font-size: 52rpx;
  font-weight: 900;
}

.brand-subtitle {
  margin-top: 16rpx;
  color: #969daa;
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.edit-card {
  padding: 46rpx 40rpx 42rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 28rpx 60rpx rgba(52, 76, 123, 0.12);
}

.avatar-wrap {
  width: 132rpx;
  height: 132rpx;
  margin: 0 auto 42rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #eef2f8;
  box-shadow: 0 10rpx 26rpx rgba(38, 52, 78, 0.12);
}

.avatar-image,
.avatar-default {
  width: 100%;
  height: 100%;
}

.avatar-default {
  position: relative;
  background: linear-gradient(135deg, #292d39, #8d96a8);
}

.avatar-default::before {
  content: "";
  position: absolute;
  left: 38rpx;
  top: 28rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
}

.avatar-default::after {
  content: "";
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  bottom: 24rpx;
  height: 36rpx;
  border-radius: 36rpx 36rpx 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
}

.default-avatar-2 { background: linear-gradient(135deg, #22577a, #57cc99); }
.default-avatar-3 { background: linear-gradient(135deg, #5f4bb6, #a4b8ff); }
.default-avatar-4 { background: linear-gradient(135deg, #f97316, #ffd166); }
.default-avatar-5 { background: linear-gradient(135deg, #0f766e, #67e8f9); }
.default-avatar-6 { background: linear-gradient(135deg, #be185d, #f9a8d4); }
.default-avatar-7 { background: linear-gradient(135deg, #334155, #94a3b8); }
.default-avatar-8 { background: linear-gradient(135deg, #2563eb, #7dd3fc); }

.profile-input {
  height: 94rpx;
  padding: 0 34rpx;
  border: 2rpx solid #d9dde5;
  border-radius: 16rpx;
  background: #fafbfe;
  color: #303747;
  font-size: 30rpx;
  box-sizing: border-box;
}

.placeholder {
  color: #adb4c0;
}

.avatar-actions {
  margin-top: 26rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
}

.avatar-btn {
  height: 78rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  box-sizing: border-box;
}

button.avatar-btn {
  padding: 0;
  line-height: 78rpx;
}

button.avatar-btn::after {
  border: 0;
}

.wechat-btn {
  background: #eef8f3;
  border: 2rpx solid #ccefe0;
  color: #16845d;
}

.upload-btn {
  background: #eef4ff;
  border: 2rpx solid #d8e6ff;
  color: #245fe0;
}

.avatar-tip {
  margin-top: 18rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
}

.action-row {
  margin-top: 36rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 22rpx;
}

.cancel-btn,
.save-btn {
  height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
}

.cancel-btn {
  background: #f4f7fb;
  border: 2rpx solid #e5ebf5;
  color: #5f6f88;
}

.save-btn {
  background: #2563eb;
  box-shadow: 0 16rpx 30rpx rgba(37, 99, 235, 0.22);
}

.save-btn.disabled {
  opacity: 0.65;
}
