@import "../store-detail/store-detail.wxss";

.product-page {
  min-height: 100vh;
  background: #f6f7fb;
}

.product-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 64rpx 1fr 128rpx;
  align-items: center;
  background: #ffffff;
  box-sizing: border-box;
}

.nav-title {
  justify-self: center;
  color: #202534;
  font-size: 30rpx;
  font-weight: 800;
}

.product-scroll {
  height: calc(100vh - 88rpx - env(safe-area-inset-top) - 112rpx);
  box-sizing: border-box;
}

.hero-wrap {
  height: 560rpx;
  background: #ffffff;
}

.hero-cover {
  width: 100%;
  height: 100%;
}

.price-band {
  margin: -34rpx 0 0;
  min-height: 132rpx;
  padding: 22rpx 32rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: linear-gradient(110deg, #fff0f0 0%, #ffe6e8 58%, #fff7d6 100%);
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: relative;
  z-index: 2;
  box-sizing: border-box;
}

.price-label,
.saving-text {
  color: #ef4444;
  font-size: 24rpx;
  font-weight: 800;
}

.price-value {
  margin-top: 4rpx;
  color: #ef4444;
  font-size: 48rpx;
  font-weight: 900;
}

.saving-text {
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.product-summary,
.detail-section {
  padding: 28rpx 32rpx;
  background: #ffffff;
}

.product-summary {
  border-bottom: 14rpx solid #f6f7fb;
}

.store-line {
  color: #8a94a8;
  font-size: 22rpx;
}

.product-title {
  margin-top: 12rpx;
  color: #1f2937;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.35;
}

.product-desc {
  margin-top: 12rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 1.65;
}

.meta-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.meta-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f2f5fa;
  color: #667085;
  font-size: 22rpx;
}

.detail-section {
  border-bottom: 14rpx solid #f6f7fb;
}

.section-title {
  color: #202534;
  font-size: 32rpx;
  font-weight: 900;
}

.detail-text {
  margin-top: 20rpx;
}

.detail-line,
.detail-empty-text {
  color: #374151;
  font-size: 28rpx;
  line-height: 1.75;
}

.detail-line + .detail-line {
  margin-top: 8rpx;
}

.detail-empty-text {
  margin-top: 16rpx;
  color: #8a94a8;
}

.param-row {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: 154rpx 1fr;
  gap: 20rpx;
  align-items: start;
}

.param-label {
  color: #8a94a8;
  font-size: 26rpx;
}

.param-value {
  color: #2f3747;
  font-size: 26rpx;
  line-height: 1.6;
}

.bottom-space {
  padding-bottom: 150rpx;
}

.checkout-bar {
  grid-template-columns: 1fr auto auto;
}
