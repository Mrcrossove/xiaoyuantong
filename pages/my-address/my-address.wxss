.address-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding-bottom: 150rpx;
}

.address-nav {
  height: 88rpx;
  padding: 0 24rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
}

.address-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
}

.nav-space {
  width: 88rpx;
}

.content-shell {
  padding: 20rpx 16rpx;
  display: grid;
  gap: 18rpx;
}

.empty-shell {
  padding: 120rpx 40rpx 0;
  text-align: center;
}

.empty-title {
  color: #7b879c;
  font-size: 28rpx;
}

.address-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(53, 88, 163, 0.08);
}

.address-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.user-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #202534;
}

.address-tag {
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  background: #eef7ee;
  color: #3d9a62;
  font-size: 20rpx;
}

.address-detail {
  margin-top: 16rpx;
  color: #647189;
  font-size: 24rpx;
  line-height: 1.7;
}

.school-line {
  margin-top: 14rpx;
  color: #3f83ff;
  font-size: 22rpx;
  font-weight: 700;
}

.address-actions {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.address-action {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #4177e2;
  font-size: 22rpx;
}

.address-action.danger {
  background: #fff0f0;
  color: #e15b5b;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border-top: 2rpx solid #edf1f5;
}

.add-btn {
  height: 92rpx;
  border-radius: 999rpx;
  background: #2f68e3;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(22, 28, 45, 0.36);
  z-index: 100;
}

.address-modal {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 32rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 60rpx rgba(30, 45, 90, 0.18);
  z-index: 101;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #202534;
}

.field-item {
  margin-top: 18rpx;
}

.field-label {
  color: #202534;
  font-size: 26rpx;
  font-weight: 600;
}

.field-value,
.field-input,
.field-textarea {
  margin-top: 12rpx;
  width: 100%;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f6f8fc;
  color: #4f5d77;
  font-size: 26rpx;
}

.field-value,
.field-input {
  min-height: 84rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
}

.field-input {
  padding-top: 24rpx;
}

.field-textarea {
  min-height: 150rpx;
  padding: 22rpx;
  line-height: 1.7;
}

.switch-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #202534;
  font-size: 26rpx;
  font-weight: 600;
}

.checkbox-label {
  display: flex;
  align-items: center;
}

.modal-actions {
  margin-top: 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.modal-btn {
  min-height: 88rpx;
  border-radius: 999rpx;
  background: #2f68e3;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.modal-btn.ghost {
  background: #eef2f8;
  color: #5f6f8d;
}
