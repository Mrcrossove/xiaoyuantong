.address-page {
  min-height: 100vh;
  padding-bottom: 156rpx;
  background:
    radial-gradient(circle at 16% 0, rgba(83, 137, 255, 0.16) 0, rgba(83, 137, 255, 0) 320rpx),
    linear-gradient(180deg, #f7faff 0, #f5f7fb 460rpx, #f6f7f9 100%);
  box-sizing: border-box;
}

.address-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
}

.back-btn {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(228, 234, 245, 0.92);
  position: relative;
  box-shadow: 0 10rpx 24rpx rgba(45, 72, 114, 0.08);
}

.address-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: #172033;
}

.nav-space {
  width: 88rpx;
}

.address-hero {
  margin: 18rpx 24rpx 0;
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #2f68e3, #22b77a);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 24rpx 50rpx rgba(47, 104, 227, 0.18);
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.address-hero::after {
  content: "";
  position: absolute;
  right: -70rpx;
  top: -70rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
}

.hero-title {
  font-size: 40rpx;
  line-height: 1.2;
  font-weight: 900;
}

.hero-subtitle {
  margin-top: 12rpx;
  width: 456rpx;
  color: rgba(255, 255, 255, 0.84);
  font-size: 25rpx;
  line-height: 1.55;
}

.hero-icon {
  width: 104rpx;
  height: 104rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.18);
  position: relative;
  z-index: 1;
}

.hero-icon::before {
  content: "";
  position: absolute;
  left: 34rpx;
  top: 22rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50% 50% 50% 0;
  border: 8rpx solid #ffffff;
  transform: rotate(-45deg);
}

.hero-icon::after {
  content: "";
  position: absolute;
  left: 40rpx;
  top: 28rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ffffff;
}

.content-shell {
  padding: 22rpx 24rpx;
  display: grid;
  gap: 20rpx;
}

.empty-shell {
  margin: 34rpx 24rpx 0;
  padding: 80rpx 36rpx;
  border-radius: 32rpx;
  background: #ffffff;
  text-align: center;
  box-shadow: 0 16rpx 38rpx rgba(50, 68, 104, 0.07);
}

.empty-visual {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 24rpx;
  border-radius: 30rpx;
  background: #eef5ff;
  position: relative;
}

.empty-visual::after {
  content: "";
  position: absolute;
  left: 38rpx;
  top: 26rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50% 50% 50% 0;
  border: 8rpx solid #5b8bf1;
  transform: rotate(-45deg);
}

.empty-title {
  color: #2b3445;
  font-size: 29rpx;
  font-weight: 800;
}

.empty-desc {
  margin-top: 12rpx;
  color: #8b95a7;
  font-size: 24rpx;
  line-height: 1.5;
}

.address-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 28rpx;
  padding: 26rpx;
  box-shadow: 0 16rpx 38rpx rgba(53, 88, 163, 0.08);
  box-sizing: border-box;
}

.address-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.user-line {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.user-name {
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 31rpx;
  font-weight: 900;
  color: #172033;
}

.user-phone {
  color: #687386;
  font-size: 25rpx;
  font-weight: 700;
}

.address-tag {
  flex: none;
  max-width: 160rpx;
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  background: #eef8f1;
  color: #26965d;
  font-size: 21rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.school-line {
  margin-top: 16rpx;
  color: #2f68e3;
  font-size: 23rpx;
  font-weight: 800;
}

.address-detail {
  margin-top: 14rpx;
  color: #4f5d72;
  font-size: 27rpx;
  line-height: 1.65;
}

.address-actions {
  margin-top: 22rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f1f4f8;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 14rpx;
}

.address-action {
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  border: 2rpx solid rgba(37, 99, 235, 0.1);
  color: #245fe0;
  font-size: 23rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
}

.address-action.danger {
  background: #fff5f5;
  border-color: #ffe0e0;
  color: #dc2626;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 2rpx solid rgba(237, 241, 245, 0.92);
  backdrop-filter: blur(18rpx);
}

.add-btn {
  height: 94rpx;
  border-radius: 999rpx;
  background: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 18rpx 34rpx rgba(37, 99, 235, 0.24);
}

.overlay {
  position: fixed;
  inset: 0;
  background: rgba(18, 25, 38, 0.46);
  z-index: 100;
}

.address-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 88vh;
  padding: 14rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx 34rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -20rpx 60rpx rgba(30, 45, 90, 0.16);
  z-index: 101;
  box-sizing: border-box;
}

.modal-handle {
  width: 76rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 999rpx;
  background: #dce2eb;
}

.modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #172033;
}

.modal-subtitle {
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.modal-close {
  flex: none;
  padding: 10rpx 12rpx;
  color: #667085;
  font-size: 26rpx;
}

.modal-body {
  margin-top: 18rpx;
  max-height: 58vh;
  padding-right: 2rpx;
  box-sizing: border-box;
}

.field-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
}

.field-item {
  margin-top: 22rpx;
}

.field-item:first-child {
  margin-top: 0;
}

.field-label {
  color: #222b3d;
  font-size: 27rpx;
  font-weight: 900;
}

.required {
  color: #ff5a5f;
}

.field-value,
.field-input,
.field-textarea {
  margin-top: 12rpx;
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #f6f8fc;
  border: 2rpx solid #edf1f6;
  color: #172033;
  font-size: 28rpx;
}

.field-value,
.field-input {
  height: 94rpx;
  line-height: 94rpx;
  padding: 0 24rpx;
}

.field-value {
  display: block;
  color: #4f5d77;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.field-textarea {
  height: 184rpx;
  min-height: 184rpx;
  padding: 22rpx 24rpx;
  line-height: 1.65;
}

.input-placeholder {
  color: #a5adbb;
}

.field-helper {
  margin-top: 10rpx;
  color: #8b95a7;
  font-size: 23rpx;
  line-height: 1.45;
}

.textarea-footer {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.textarea-footer .field-helper {
  flex: 1;
}

.counter {
  flex: none;
  margin-top: 10rpx;
  color: #8b95a7;
  font-size: 23rpx;
}

.counter.warn {
  color: #d06b24;
}

.switch-row {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #f6f8fc;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.switch-title {
  color: #222b3d;
  font-size: 27rpx;
  font-weight: 900;
}

.switch-desc {
  margin-top: 8rpx;
  color: #8b95a7;
  font-size: 23rpx;
}

.modal-actions {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.modal-btn {
  min-height: 92rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.2);
}

.modal-btn.ghost {
  background: #f4f7fb;
  border: 2rpx solid #e5ebf5;
  color: #5f6f88;
  box-shadow: none;
}

.modal-btn.disabled {
  opacity: 0.7;
}
