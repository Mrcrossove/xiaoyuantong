.storefront-page {
  min-height: 100vh;
  padding-bottom: 170rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef2f7 100%);
}

.storefront-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.96);
}

.nav-spacer {
  width: 140rpx;
}

.storefront-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #202534;
}

.storefront-body {
  padding: 20rpx 24rpx 0;
}

.top-filter-row {
  display: grid;
  grid-template-columns: 176rpx 1fr;
  gap: 14rpx;
  align-items: center;
}

.current-school {
  min-width: 0;
  height: 88rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(57, 85, 142, 0.1);
  color: #4a83ff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  box-sizing: border-box;
}

.current-school text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.school-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #4a83ff;
  border-bottom: 4rpx solid #4a83ff;
  transform: rotate(45deg) translateY(-3rpx);
  flex: 0 0 auto;
}

.search-card,
.category-card,
.banner-card,
.shop-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(57, 85, 142, 0.1);
}

.search-card {
  padding: 6rpx;
}

.search-field {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f1f4f9;
}

.school-picker-mask {
  position: fixed;
  inset: 0;
  background: rgba(21, 30, 53, 0.42);
  z-index: 80;
  display: flex;
  align-items: flex-end;
}

.school-picker {
  width: 100%;
  max-height: 78vh;
  padding: 24rpx;
  border-radius: 32rpx 32rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.school-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-picker-title {
  color: #202534;
  font-size: 32rpx;
  font-weight: 800;
}

.school-picker-close {
  color: #5f6f88;
  font-size: 24rpx;
  font-weight: 700;
}

.school-picker-search {
  margin-top: 20rpx;
  height: 76rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f4f7fb;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.school-picker-search input {
  flex: 1;
  font-size: 26rpx;
}

.school-list {
  margin-top: 18rpx;
  max-height: 58vh;
}

.school-group + .school-group {
  border-top: 2rpx solid #eef2f8;
}

.school-group-head {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-group-title {
  color: #202534;
  font-size: 26rpx;
  font-weight: 800;
}

.school-group-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #9aa5bb;
  border-bottom: 4rpx solid #9aa5bb;
  transform: rotate(45deg);
}

.school-group-arrow.expanded {
  transform: rotate(225deg);
}

.school-group-body {
  display: grid;
  gap: 10rpx;
  padding-bottom: 16rpx;
}

.school-item {
  min-height: 68rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
  color: #46546a;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.school-item.active {
  background: #eaf2ff;
  color: #245fe0;
  font-weight: 800;
}

.school-item-mark {
  flex: 0 0 auto;
  color: #245fe0;
  font-size: 22rpx;
}

.school-empty {
  padding: 48rpx 0;
  color: #8a95aa;
  font-size: 24rpx;
  text-align: center;
}

.search-field input {
  flex: 1;
  font-size: 28rpx;
}

.search-icon {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #99a6bc;
  border-radius: 50%;
  position: relative;
  flex: 0 0 auto;
}

.search-icon::after {
  content: "";
  position: absolute;
  width: 10rpx;
  height: 4rpx;
  right: -8rpx;
  bottom: -3rpx;
  border-radius: 999rpx;
  background: #99a6bc;
  transform: rotate(45deg);
}

.search-placeholder {
  color: #a5afbf;
}

.category-card {
  margin-top: 20rpx;
  padding: 18rpx 14rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.category-item {
  min-height: 156rpx;
  padding: 16rpx 6rpx 14rpx;
  border-radius: 24rpx;
  background: #f8fbff;
  display: grid;
  justify-items: center;
  align-content: center;
  gap: 10rpx;
  color: #3b465a;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 700;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: transform 0.18s ease;
}

.category-item::before {
  content: "";
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  top: 10rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.44);
}

.category-item:active {
  transform: scale(0.96);
}

.category-item:nth-child(1) {
  background: linear-gradient(180deg, #fff8e7 0%, #fff1f1 100%);
}

.category-item:nth-child(2) {
  background: linear-gradient(180deg, #eef5ff 0%, #f7faff 100%);
}

.category-item:nth-child(3) {
  background: linear-gradient(180deg, #effdf7 0%, #f7fffb 100%);
}

.category-item:nth-child(4) {
  background: linear-gradient(180deg, #f5f0ff 0%, #fbf8ff 100%);
}

.category-label {
  position: relative;
  z-index: 1;
  white-space: nowrap;
}

.category-badge {
  width: 76rpx;
  height: 76rpx;
  border-radius: 26rpx;
  background: #ffffff;
  position: relative;
  box-shadow: 0 14rpx 26rpx rgba(48, 65, 110, 0.12);
  z-index: 1;
  overflow: hidden;
}

.category-badge::before,
.category-badge::after,
.category-symbol,
.category-symbol::before,
.category-symbol::after {
  content: "";
  position: absolute;
}

.icon-student::before {
  inset: 0;
  background: linear-gradient(135deg, #ffcf67, #ff8f70);
}

.icon-student .category-symbol {
  left: 27rpx;
  top: 16rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #fff6db;
}

.icon-student .category-symbol::before {
  left: -12rpx;
  top: 29rpx;
  width: 46rpx;
  height: 26rpx;
  border-radius: 22rpx 22rpx 10rpx 10rpx;
  background: #4f85ff;
}

.icon-student .category-symbol::after {
  right: -20rpx;
  top: 38rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #fff6db;
}

.icon-dorm::before {
  inset: 0;
  background: linear-gradient(135deg, #7fb4ff, #5c7cff);
}

.icon-dorm .category-symbol {
  left: 18rpx;
  bottom: 14rpx;
  width: 40rpx;
  height: 34rpx;
  border-radius: 8rpx;
  background: #fff8e8;
  box-shadow: inset 0 -6rpx 0 rgba(76, 105, 222, 0.13);
}

.icon-dorm .category-symbol::before {
  left: -8rpx;
  top: -16rpx;
  width: 56rpx;
  height: 22rpx;
  border-radius: 6rpx;
  background: #ff8f74;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.icon-dorm .category-symbol::after {
  left: 15rpx;
  bottom: 0;
  width: 10rpx;
  height: 16rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: #5c7cff;
}

.icon-campus::before {
  inset: 0;
  background: linear-gradient(135deg, #77dfbd, #2fc0a4);
}

.icon-campus .category-symbol {
  left: 17rpx;
  top: 25rpx;
  width: 42rpx;
  height: 30rpx;
  border-radius: 8rpx;
  background: #fff8d7;
}

.icon-campus .category-symbol::before {
  left: -6rpx;
  top: -16rpx;
  width: 54rpx;
  height: 22rpx;
  border-radius: 6rpx;
  background: #ffcf5e;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.icon-campus .category-symbol::after {
  left: 8rpx;
  top: 12rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 3rpx;
  background: #2aa78e;
  box-shadow: 18rpx 0 0 #2aa78e, 9rpx 12rpx 0 #2aa78e;
}

.icon-offCampus::before {
  inset: 0;
  background: linear-gradient(135deg, #b59cff, #7c6bff);
}

.icon-offCampus .category-symbol {
  left: 15rpx;
  top: 24rpx;
  width: 46rpx;
  height: 32rpx;
  border-radius: 9rpx;
  background: #fff5df;
}

.icon-offCampus .category-symbol::before {
  left: -7rpx;
  top: -15rpx;
  width: 58rpx;
  height: 22rpx;
  border-radius: 6rpx;
  background: #ffc35c;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.icon-offCampus .category-symbol::after {
  right: 7rpx;
  top: 11rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #7c6bff;
  box-shadow: -17rpx 0 0 #7c6bff;
}

.banner-card {
  margin-top: 20rpx;
  padding: 24rpx;
  display: grid;
  grid-template-columns: 1.2fr 0.9fr;
  gap: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f7fbff, #fff4dd);
}

.banner-copy {
  position: relative;
  z-index: 1;
}

.banner-tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #ffd04e;
  color: #7e4e00;
  font-size: 20rpx;
  font-weight: 700;
}

.banner-title {
  margin-top: 16rpx;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #233157;
}

.banner-desc {
  margin-top: 12rpx;
  color: #60708b;
  font-size: 24rpx;
  line-height: 1.6;
}

.banner-cta {
  margin-top: 20rpx;
  display: inline-flex;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #ffb930;
  color: #7a4b00;
  font-size: 22rpx;
  font-weight: 700;
}

.banner-art {
  position: relative;
  min-height: 180rpx;
}

.art-circle {
  position: absolute;
  border-radius: 50%;
}

.art-circle.big {
  right: -20rpx;
  top: -10rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 193, 59, 0.2);
}

.art-circle.small {
  left: 12rpx;
  bottom: 10rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(93, 140, 255, 0.12);
}

.art-person {
  position: absolute;
  bottom: 0;
  width: 54rpx;
  border-radius: 24rpx 24rpx 12rpx 12rpx;
}

.art-person::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: -26rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: inherit;
}

.art-person.one {
  left: 18rpx;
  height: 90rpx;
  background: #5b88ff;
}

.art-person.two {
  left: 78rpx;
  height: 72rpx;
  background: #ff9154;
}

.art-person.three {
  right: 18rpx;
  height: 108rpx;
  background: #f3c03a;
}

.shop-list {
  margin-top: 20rpx;
  display: grid;
  gap: 18rpx;
}

.shop-card {
  padding: 20rpx;
  display: grid;
  grid-template-columns: 112rpx 1fr;
  gap: 18rpx;
  align-items: start;
}

.shop-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

.shop-cover-image {
  display: block;
  background: #e8edf7;
}

.shop-cover::before,
.shop-cover::after {
  content: "";
  position: absolute;
}

.cover-store-mini {
  background: linear-gradient(180deg, #7a654f, #d4c2a8);
}

.cover-store-mini::before {
  inset: 18rpx;
  border-radius: 12rpx;
  background: #f7f0e7;
}

.cover-store-mini::after {
  left: 22rpx;
  right: 22rpx;
  top: 22rpx;
  height: 18rpx;
  background: #8d623d;
}

.cover-store-sichuan {
  background: linear-gradient(180deg, #3a2a28, #db6a3b);
}

.cover-store-sichuan::before {
  left: 14rpx;
  right: 14rpx;
  bottom: 18rpx;
  height: 38rpx;
  border-radius: 10rpx;
  background: #f0d3a1;
}

.cover-store-sichuan::after {
  left: 12rpx;
  right: 12rpx;
  top: 20rpx;
  height: 20rpx;
  background: #f5cb49;
}

.cover-store-canteen {
  background: linear-gradient(180deg, #f9f6ef, #cfd7e6);
}

.cover-store-canteen::before {
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  height: 44rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 2rpx rgba(115, 129, 161, 0.15);
}

.cover-store-canteen::after {
  left: 16rpx;
  right: 16rpx;
  top: 18rpx;
  height: 22rpx;
  background: #f0b24c;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.cover-store-flower {
  background: linear-gradient(180deg, #dfe9d5, #f7d6d6);
}

.cover-store-flower::before {
  left: 24rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff8ba0;
  box-shadow: 22rpx 8rpx 0 #ffd05f, 8rpx 30rpx 0 #8fcf6d, 34rpx 34rpx 0 #ffb574;
}

.cover-store-flower::after {
  left: 34rpx;
  bottom: 18rpx;
  width: 6rpx;
  height: 28rpx;
  background: #5f9d57;
  box-shadow: 16rpx -4rpx 0 #5f9d57, -10rpx 0 0 #5f9d57;
}

.shop-main {
  min-width: 0;
}

.shop-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.shop-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2738;
}

.shop-badge {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ffe7d5;
  color: #ff7c45;
  font-size: 20rpx;
  font-weight: 700;
}

.shop-meta,
.shop-service {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #7f899d;
  font-size: 22rpx;
}

.star {
  color: #ffbe2e;
}

.shop-service {
  color: #59647a;
  line-height: 1.45;
}

.shop-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.recommend-preview {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: #fff8eb;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.recommend-preview-label {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #ffdd95;
  color: #9a6112;
  font-size: 18rpx;
  font-weight: 700;
}

.recommend-preview-name {
  color: #5f4a21;
  font-size: 22rpx;
  font-weight: 700;
}

.recommend-preview-price {
  color: #eb6b3f;
  font-size: 22rpx;
  font-weight: 800;
}

.shop-tag {
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  background: #edf4ff;
  color: #5e88d9;
  font-size: 20rpx;
}

.custom-tag {
  background: #fff2e8;
  color: #df6f22;
}

.school-tag {
  background: #eef9ee;
  color: #54a26d;
}

.recommend-tag {
  background: #fff4d8;
  color: #d88918;
}

.platform-tag {
  background: linear-gradient(135deg, #1f7aff, #20c7a5);
  color: #ffffff;
}

.shop-empty-card {
  margin-top: 20rpx;
  padding: 56rpx 36rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(57, 85, 142, 0.1);
  text-align: center;
}

.shop-empty-title {
  color: #202534;
  font-size: 32rpx;
  font-weight: 700;
}

.shop-empty-desc {
  margin-top: 14rpx;
  color: #8590a7;
  font-size: 24rpx;
  line-height: 1.7;
}

.shop-empty-actions {
  margin-top: 26rpx;
  display: flex;
  justify-content: center;
}

.shop-empty-btn {
  min-width: 220rpx;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: #f0f4fb;
  color: #51607b;
  font-size: 24rpx;
  font-weight: 700;
}

.shop-empty-btn.primary {
  background: #ffb930;
  color: #7a4b00;
}
