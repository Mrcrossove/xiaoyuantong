.storefront-page {
  min-height: 100vh;
  padding-bottom: 170rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef2f7 100%);
}

.storefront-nav {
  height: 88rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.96);
}

.nav-spacer {
  width: 140rpx;
}

.storefront-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #202534;
}

.storefront-body {
  padding: 20rpx 24rpx 0;
}

.current-school {
  margin-bottom: 16rpx;
  color: #4a83ff;
  font-size: 24rpx;
  font-weight: 700;
}

.search-card,
.category-card,
.banner-card,
.shop-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(57, 85, 142, 0.1);
}

.search-card {
  padding: 18rpx;
}

.search-field {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 76rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #f1f4f9;
}

.search-field input {
  flex: 1;
  font-size: 28rpx;
}

.search-icon {
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #99a6bc;
  border-radius: 50%;
  position: relative;
  flex: 0 0 auto;
}

.search-icon::after {
  content: "";
  position: absolute;
  width: 10rpx;
  height: 4rpx;
  right: -8rpx;
  bottom: -3rpx;
  border-radius: 999rpx;
  background: #99a6bc;
  transform: rotate(45deg);
}

.search-placeholder {
  color: #a5afbf;
}

.category-card {
  margin-top: 20rpx;
  padding: 26rpx 20rpx 18rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.category-item {
  display: grid;
  justify-items: center;
  gap: 12rpx;
  color: #5f6980;
  font-size: 22rpx;
}

.category-badge {
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #eef4ff, #dce7ff);
  position: relative;
  box-shadow: inset 0 -10rpx 18rpx rgba(111, 148, 234, 0.18);
}

.category-badge::before,
.category-badge::after {
  content: "";
  position: absolute;
}

.icon-student::before {
  left: 30rpx;
  top: 18rpx;
  width: 32rpx;
  height: 24rpx;
  border-radius: 16rpx 16rpx 8rpx 8rpx;
  background: #ffb25a;
}

.icon-student::after {
  left: 22rpx;
  bottom: 18rpx;
  width: 48rpx;
  height: 28rpx;
  border-radius: 18rpx 18rpx 12rpx 12rpx;
  background: #4f85ff;
}

.icon-dorm::before {
  left: 22rpx;
  top: 22rpx;
  width: 48rpx;
  height: 42rpx;
  border-radius: 10rpx;
  background: #ff8d74;
}

.icon-dorm::after {
  left: 16rpx;
  top: 14rpx;
  width: 60rpx;
  height: 20rpx;
  background: #546cf7;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.icon-campus::before {
  left: 20rpx;
  top: 28rpx;
  width: 52rpx;
  height: 34rpx;
  border-radius: 8rpx;
  background: #5dd2b7;
}

.icon-campus::after {
  left: 14rpx;
  top: 18rpx;
  width: 64rpx;
  height: 18rpx;
  background: #ffd45d;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.icon-offCampus::before {
  left: 20rpx;
  top: 26rpx;
  width: 54rpx;
  height: 36rpx;
  border-radius: 10rpx;
  background: #9c86ff;
}

.icon-offCampus::after {
  left: 16rpx;
  top: 16rpx;
  width: 62rpx;
  height: 20rpx;
  background: #ffb758;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.banner-card {
  margin-top: 20rpx;
  padding: 24rpx;
  display: grid;
  grid-template-columns: 1.2fr 0.9fr;
  gap: 18rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f7fbff, #fff4dd);
}

.banner-copy {
  position: relative;
  z-index: 1;
}

.banner-tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #ffd04e;
  color: #7e4e00;
  font-size: 20rpx;
  font-weight: 700;
}

.banner-title {
  margin-top: 16rpx;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #233157;
}

.banner-desc {
  margin-top: 12rpx;
  color: #60708b;
  font-size: 24rpx;
  line-height: 1.6;
}

.banner-cta {
  margin-top: 20rpx;
  display: inline-flex;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background: #ffb930;
  color: #7a4b00;
  font-size: 22rpx;
  font-weight: 700;
}

.banner-art {
  position: relative;
  min-height: 180rpx;
}

.art-circle {
  position: absolute;
  border-radius: 50%;
}

.art-circle.big {
  right: -20rpx;
  top: -10rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 193, 59, 0.2);
}

.art-circle.small {
  left: 12rpx;
  bottom: 10rpx;
  width: 100rpx;
  height: 100rpx;
  background: rgba(93, 140, 255, 0.12);
}

.art-person {
  position: absolute;
  bottom: 0;
  width: 54rpx;
  border-radius: 24rpx 24rpx 12rpx 12rpx;
}

.art-person::before {
  content: "";
  position: absolute;
  left: 11rpx;
  top: -26rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: inherit;
}

.art-person.one {
  left: 18rpx;
  height: 90rpx;
  background: #5b88ff;
}

.art-person.two {
  left: 78rpx;
  height: 72rpx;
  background: #ff9154;
}

.art-person.three {
  right: 18rpx;
  height: 108rpx;
  background: #f3c03a;
}

.shop-list {
  margin-top: 20rpx;
  display: grid;
  gap: 18rpx;
}

.shop-card {
  padding: 20rpx;
  display: grid;
  grid-template-columns: 112rpx 1fr auto;
  gap: 18rpx;
  align-items: start;
}

.shop-cover {
  width: 112rpx;
  height: 112rpx;
  border-radius: 20rpx;
  position: relative;
  overflow: hidden;
}

.shop-cover-image {
  display: block;
  background: #e8edf7;
}

.shop-cover::before,
.shop-cover::after {
  content: "";
  position: absolute;
}

.cover-store-mini {
  background: linear-gradient(180deg, #7a654f, #d4c2a8);
}

.cover-store-mini::before {
  inset: 18rpx;
  border-radius: 12rpx;
  background: #f7f0e7;
}

.cover-store-mini::after {
  left: 22rpx;
  right: 22rpx;
  top: 22rpx;
  height: 18rpx;
  background: #8d623d;
}

.cover-store-sichuan {
  background: linear-gradient(180deg, #3a2a28, #db6a3b);
}

.cover-store-sichuan::before {
  left: 14rpx;
  right: 14rpx;
  bottom: 18rpx;
  height: 38rpx;
  border-radius: 10rpx;
  background: #f0d3a1;
}

.cover-store-sichuan::after {
  left: 12rpx;
  right: 12rpx;
  top: 20rpx;
  height: 20rpx;
  background: #f5cb49;
}

.cover-store-canteen {
  background: linear-gradient(180deg, #f9f6ef, #cfd7e6);
}

.cover-store-canteen::before {
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  height: 44rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: inset 0 0 0 2rpx rgba(115, 129, 161, 0.15);
}

.cover-store-canteen::after {
  left: 16rpx;
  right: 16rpx;
  top: 18rpx;
  height: 22rpx;
  background: #f0b24c;
  clip-path: polygon(50% 0, 100% 100%, 0 100%);
}

.cover-store-flower {
  background: linear-gradient(180deg, #dfe9d5, #f7d6d6);
}

.cover-store-flower::before {
  left: 24rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: #ff8ba0;
  box-shadow: 22rpx 8rpx 0 #ffd05f, 8rpx 30rpx 0 #8fcf6d, 34rpx 34rpx 0 #ffb574;
}

.cover-store-flower::after {
  left: 34rpx;
  bottom: 18rpx;
  width: 6rpx;
  height: 28rpx;
  background: #5f9d57;
  box-shadow: 16rpx -4rpx 0 #5f9d57, -10rpx 0 0 #5f9d57;
}

.shop-main {
  min-width: 0;
}

.shop-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.shop-name {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2738;
}

.shop-badge {
  flex: 0 0 auto;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #ffe7d5;
  color: #ff7c45;
  font-size: 20rpx;
  font-weight: 700;
}

.shop-meta,
.shop-service {
  margin-top: 10rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  color: #7f899d;
  font-size: 22rpx;
}

.star {
  color: #ffbe2e;
}

.shop-service {
  color: #ff8a56;
}

.shop-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.recommend-preview {
  margin-top: 12rpx;
  padding: 12rpx 14rpx;
  border-radius: 16rpx;
  background: #fff8eb;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.recommend-preview-label {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #ffdd95;
  color: #9a6112;
  font-size: 18rpx;
  font-weight: 700;
}

.recommend-preview-name {
  color: #5f4a21;
  font-size: 22rpx;
  font-weight: 700;
}

.recommend-preview-price {
  color: #eb6b3f;
  font-size: 22rpx;
  font-weight: 800;
}

.shop-tag {
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  background: #edf4ff;
  color: #5e88d9;
  font-size: 20rpx;
}

.school-tag {
  background: #eef9ee;
  color: #54a26d;
}

.recommend-tag {
  background: #fff4d8;
  color: #d88918;
}

.shop-distance {
  color: #ff8b85;
  font-size: 20rpx;
  padding-top: 4rpx;
}

.shop-empty-card {
  margin-top: 20rpx;
  padding: 56rpx 36rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 44rpx rgba(57, 85, 142, 0.1);
  text-align: center;
}

.shop-empty-title {
  color: #202534;
  font-size: 32rpx;
  font-weight: 700;
}

.shop-empty-desc {
  margin-top: 14rpx;
  color: #8590a7;
  font-size: 24rpx;
  line-height: 1.7;
}
