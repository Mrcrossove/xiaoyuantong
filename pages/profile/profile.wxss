.profile-page {
  min-height: 100vh;
  padding: 0 16rpx 160rpx;
  background: #f5f5f6;
}

.profile-nav {
  height: 88rpx;
  padding: 0 8rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #ffffff;
}

.profile-nav-spacer {
  width: 140rpx;
}

.profile-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #202534;
}

.profile-card {
  margin-top: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 12rpx 28rpx rgba(59, 80, 122, 0.08);
  padding: 22rpx;
}

.user-card {
  display: grid;
  grid-template-columns: 84rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
}

.user-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  position: relative;
  overflow: hidden;
  background: #eef2f8;
}

.user-avatar-image,
.user-avatar-default {
  width: 100%;
  height: 100%;
}

.user-avatar-default {
  position: relative;
  background: linear-gradient(135deg, #23262f, #848a97);
}

.user-avatar-default::before {
  content: "";
  position: absolute;
  inset: 16rpx 18rpx 28rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.user-avatar-default::after {
  content: "";
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 14rpx;
  height: 22rpx;
  border-radius: 24rpx 24rpx 30rpx 30rpx;
  background: rgba(255, 255, 255, 0.88);
}

.default-avatar-2 { background: linear-gradient(135deg, #22577a, #57cc99); }
.default-avatar-3 { background: linear-gradient(135deg, #5f4bb6, #a4b8ff); }
.default-avatar-4 { background: linear-gradient(135deg, #f97316, #ffd166); }
.default-avatar-5 { background: linear-gradient(135deg, #0f766e, #67e8f9); }
.default-avatar-6 { background: linear-gradient(135deg, #be185d, #f9a8d4); }
.default-avatar-7 { background: linear-gradient(135deg, #334155, #94a3b8); }
.default-avatar-8 { background: linear-gradient(135deg, #2563eb, #7dd3fc); }

.avatar-verified-dot {
  position: absolute;
  right: 0;
  bottom: 2rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #28b26d;
  box-shadow: 0 0 0 4rpx #ffffff;
  z-index: 2;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #202534;
}

.verify-badge {
  padding-left: 22rpx;
  position: relative;
  color: #5a9cff;
  font-size: 22rpx;
}

.verify-badge::before {
  content: "";
  position: absolute;
  left: 0;
  top: 3rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #5a9cff;
}

.user-school {
  margin-top: 8rpx;
  color: #8d95a8;
  font-size: 22rpx;
}

.edit-text {
  align-self: center;
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f4f7fb;
  border: 2rpx solid #e5ebf5;
  color: #245fe0;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
}

.verify-guide-card {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #fff7df, #eef7ff);
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 12rpx 28rpx rgba(59, 80, 122, 0.08);
}

.verify-guide-main {
  flex: 1;
  min-width: 0;
}

.verify-guide-title {
  color: #22304a;
  font-size: 30rpx;
  font-weight: 800;
}

.verify-guide-desc {
  margin-top: 10rpx;
  color: #66738a;
  font-size: 24rpx;
  line-height: 1.55;
}

.verify-guide-btn {
  flex: 0 0 auto;
  height: 68rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.2);
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #2a3040;
}

.content-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  row-gap: 24rpx;
}

.content-item {
  display: grid;
  justify-items: center;
  gap: 12rpx;
  color: #5f6f88;
  font-size: 22rpx;
  font-weight: 700;
}

.content-icon,
.setting-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 22rpx;
  background: #f1f6ff;
  border: 2rpx solid #e2ebff;
  position: relative;
  box-shadow: 0 8rpx 18rpx rgba(61, 124, 255, 0.08);
}

.content-icon::before,
.setting-icon::before {
  content: "";
  position: absolute;
  inset: 0;
  background: transparent;
}

.icon-order::after,
.icon-publish::after,
.icon-favorite::after,
.icon-shop::after,
.icon-address::after,
.icon-verify::after,
.icon-service::after,
.icon-about::after {
  content: "";
  position: absolute;
}

.icon-order::after {
  left: 19rpx;
  top: 18rpx;
  width: 24rpx;
  height: 22rpx;
  border: 4rpx solid #3d7cff;
  border-radius: 8rpx;
  box-shadow: inset 0 8rpx 0 rgba(61, 124, 255, 0.12);
}

.icon-publish::after {
  left: 27rpx;
  top: 17rpx;
  width: 8rpx;
  height: 28rpx;
  background: #3d7cff;
  box-shadow: -10rpx 10rpx 0 #3d7cff, 10rpx -10rpx 0 #3d7cff;
  transform: rotate(45deg);
}

.icon-favorite::after {
  inset: 16rpx;
  background: #3d7cff;
  clip-path: polygon(50% 100%, 0 45%, 16% 16%, 38% 16%, 50% 30%, 62% 16%, 84% 16%, 100% 45%);
}

.icon-shop::after {
  left: 18rpx;
  top: 21rpx;
  width: 26rpx;
  height: 20rpx;
  border: 4rpx solid #3d7cff;
  border-radius: 6rpx;
}

.icon-address::after {
  left: 22rpx;
  top: 14rpx;
  width: 18rpx;
  height: 28rpx;
  border-radius: 50% 50% 50% 0;
  background: #3d7cff;
  transform: rotate(-45deg);
}

.icon-verify::after {
  left: 18rpx;
  top: 14rpx;
  width: 26rpx;
  height: 30rpx;
  background: #3d7cff;
  clip-path: polygon(50% 0, 100% 32%, 100% 100%, 0 100%, 0 32%);
}

.icon-service::after {
  left: 19rpx;
  top: 17rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid #3d7cff;
  box-sizing: border-box;
}

.icon-service::before {
  display: block;
  left: 27rpx;
  top: 25rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #3d7cff;
}

.icon-about::after {
  left: 28rpx;
  top: 23rpx;
  width: 6rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: #3d7cff;
  box-shadow: 0 -10rpx 0 #3d7cff;
}

.setting-row {
  min-height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.contact-service-button {
  width: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: 0;
  border-radius: 0;
  color: inherit;
  font: inherit;
  line-height: normal;
  text-align: left;
}

.contact-service-button::after {
  border: 0;
}

.setting-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.setting-status {
  color: #8d95a8;
  font-size: 24rpx;
}

.setting-status.done {
  color: #26a66a;
  font-weight: 700;
}

.setting-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  color: #2f3340;
  font-size: 28rpx;
  font-weight: 700;
}

.setting-arrow {
  width: 18rpx;
  height: 18rpx;
  border-top: 4rpx solid #b3bbca;
  border-right: 4rpx solid #b3bbca;
  transform: rotate(45deg);
}

.logout-btn {
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  height: 92rpx;
  border: 2rpx solid #ffe0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #e5484d;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 24rpx rgba(229, 72, 77, 0.08);
}

.logout-btn.login {
  color: #ffffff;
  background: #2563eb;
  border-color: #2563eb;
  box-shadow: 0 14rpx 28rpx rgba(37, 99, 235, 0.2);
}
