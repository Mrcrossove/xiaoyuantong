<view class="profile-page" style="padding-top: {{statusBarHeight}}px;">
  <view class="profile-nav">
    <view class="profile-nav-spacer"></view>
    <view class="profile-title">我的</view>
    <view class="profile-nav-spacer"></view>
  </view>

  <view class="profile-card user-card">
    <view class="user-avatar" bindtap="openProfileEdit">
      <image wx:if="{{!user.avatar.isDefaultAvatar}}" class="user-avatar-image" src="{{user.avatar.avatarUrl}}" mode="aspectFill"></image>
      <view wx:else class="user-avatar-default {{user.avatar.defaultAvatarClass}}"></view>
      <view wx:if="{{user.verified}}" class="avatar-verified-dot"></view>
    </view>
    <view class="user-meta">
      <view class="user-name-row">
        <text class="user-name">{{user.name}}</text>
        <text wx:if="{{user.verified}}" class="verify-badge">已认证</text>
      </view>
      <text class="user-school">{{user.school}}</text>
      <view class="user-verify-entry" bindtap="openCampusVerify">
        <text class="verify-entry-text {{user.verified ? 'done' : ''}}">
          {{user.verified ? "绿色认证状态已开启" : "去认证，解锁更多校园服务"}}
        </text>
        <view class="setting-arrow"></view>
      </view>
    </view>
    <view class="edit-text" bindtap="openProfileEdit">编辑</view>
  </view>

  <view wx:if="{{!user.verified}}" class="verify-guide-card" bindtap="openCampusVerify">
    <view class="verify-guide-main">
      <view class="verify-guide-title">完成校园认证，解锁完整服务</view>
      <view class="verify-guide-desc">认证后可发布帖子、申请开店、参与校园交易，内容也会优先展示你所在学校。</view>
    </view>
    <view class="verify-guide-btn">去认证</view>
  </view>

  <view class="profile-card">
    <view class="section-title">我的内容</view>
    <view class="content-grid">
      <view class="content-item" wx:for="{{contentItems}}" wx:key="label" data-icon="{{item.icon}}" bindtap="onContentTap">
        <view class="content-icon icon-{{item.icon}}"></view>
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="profile-card">
    <view class="section-title">认证中心</view>
    <view class="setting-row" bindtap="openCampusVerify">
      <view class="setting-left">
        <view class="setting-icon icon-verify"></view>
        <text>校园认证</text>
      </view>
      <view class="setting-right">
        <text class="setting-status {{user.verified ? 'done' : ''}}">{{user.statusText}}</text>
        <view class="setting-arrow"></view>
      </view>
    </view>
  </view>

  <view class="profile-card">
    <view class="section-title">设置与支持</view>
    <block wx:for="{{supportItems}}" wx:key="label">
      <button
        wx:if="{{item.icon == 'service'}}"
        class="setting-row contact-service-btn"
        open-type="contact"
        send-message-title="校园通客服"
        send-message-path="/pages/profile/profile"
        show-message-card="true"
      >
        <view class="setting-left">
          <view class="setting-icon icon-{{item.icon}}"></view>
          <text>{{item.label}}</text>
        </view>
      </button>
      <view wx:else class="setting-row" data-icon="{{item.icon}}" bindtap="onSupportTap">
        <view class="setting-left">
          <view class="setting-icon icon-{{item.icon}}"></view>
          <text>{{item.label}}</text>
        </view>
        <view wx:if="{{item.arrow}}" class="setting-arrow"></view>
      </view>
    </block>
  </view>

  <view class="logout-btn" bindtap="handleLogout">{{logoutText}}</view>

  <view class="tabbar card">
    <view class="tab" bindtap="goHome">
      <view class="tab-icon home"></view>
      <text>首页</text>
    </view>
    <view class="tab" bindtap="goStorefront">
      <view class="tab-icon shop"></view>
      <text>创业店铺</text>
    </view>
    <view class="tab" bindtap="goMessage">
      <view class="tab-icon message"></view>
      <text>消息</text>
    </view>
    <view class="tab active">
      <view class="tab-icon user"></view>
      <text>我的</text>
    </view>
  </view>
</view>
