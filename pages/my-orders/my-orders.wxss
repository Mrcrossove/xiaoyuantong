.order-page {
  min-height: 100vh;
  background: #f5f7fb;
}

.order-nav {
  height: 88rpx;
  padding: 0 24rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: 88rpx 1fr 88rpx;
  align-items: center;
}

.order-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: 700;
  color: #202534;
}

.nav-space {
  width: 88rpx;
}

.tab-row {
  margin: 20rpx 16rpx 0;
  padding: 10rpx;
  border-radius: 24rpx;
  background: #ffffff;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
}

.tab-item {
  height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7f8aa0;
  font-size: 24rpx;
}

.tab-item.active {
  background: #edf4ff;
  color: #2f68e3;
  font-weight: 700;
}

.content-shell {
  padding: 20rpx 16rpx 32rpx;
  display: grid;
  gap: 18rpx;
}

.order-card {
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 16rpx 36rpx rgba(53, 88, 163, 0.08);
  padding: 24rpx;
}

.order-head,
.order-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.order-id {
  color: #68758d;
  font-size: 22rpx;
}

.order-status {
  font-size: 24rpx;
  font-weight: 700;
}

.status-pending {
  color: #ff9b2f;
}

.status-processing {
  color: #29a36a;
}

.status-finished {
  color: #2f68e3;
}

.status-canceled {
  color: #e15b5b;
}

.order-title-line {
  margin-top: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #202534;
}

.order-desc {
  margin-top: 12rpx;
  color: #7a869d;
  font-size: 24rpx;
  line-height: 1.7;
}

.order-items {
  margin-top: 14rpx;
  padding: 14rpx 16rpx;
  border-radius: 16rpx;
  background: #f7f9fc;
  display: grid;
  gap: 8rpx;
}

.order-item-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #5f6f88;
  font-size: 22rpx;
}

.order-meta {
  margin-top: 16rpx;
  color: #596885;
  font-size: 24rpx;
}

.order-time {
  margin-top: 12rpx;
  color: #9ca6b9;
  font-size: 22rpx;
}

.order-actions {
  margin-top: 20rpx;
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
}

.order-action {
  min-width: 168rpx;
  height: 68rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.order-action.primary {
  background: #2563eb;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.18);
}

.order-action.ghost {
  background: #f4f7fb;
  border: 2rpx solid #e5ebf5;
  color: #5f6f88;
}

.empty-shell {
  margin: 28rpx 16rpx 0;
  padding: 96rpx 40rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 36rpx rgba(53, 88, 163, 0.08);
  text-align: center;
}

.empty-illustration {
  width: 156rpx;
  height: 132rpx;
  margin: 0 auto 28rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #f3f7ff, #e8effb);
  position: relative;
  overflow: hidden;
}

.empty-line {
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  top: 58rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #b8c6dd;
}

.empty-line.short {
  top: 38rpx;
  right: 62rpx;
}

.empty-dot {
  position: absolute;
  right: 34rpx;
  bottom: 30rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #8db1ff;
}

.empty-title {
  color: #7b879c;
  font-size: 28rpx;
}

.empty-btn {
  width: 280rpx;
  height: 88rpx;
  margin: 28rpx auto 0;
  border-radius: 999rpx;
  background: #2f68e3;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}
