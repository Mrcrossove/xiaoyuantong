.login-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-left: 40rpx;
  padding-right: 40rpx;
  background: linear-gradient(180deg, #f7f9ff 0%, #ffffff 48%, #ffffff 100%);
}

.login-system-space {
  height: 120rpx;
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-logo {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 22rpx 46rpx rgba(57, 136, 228, 0.2);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-logo-image {
  width: 108rpx;
  height: 108rpx;
  display: block;
}

.brand-title {
  margin-top: 58rpx;
  color: #252a33;
  font-size: 54rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  margin-top: 22rpx;
  color: #a2a8b3;
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.login-actions {
  margin-top: 330rpx;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 28rpx;
}

.checkbox {
  flex: 0 0 auto;
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 2rpx solid #c6cedb;
  background: #ffffff;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 3rpx;
}

.checkbox.checked {
  border-color: #2563eb;
  background: #2563eb;
}

.agreement-text {
  flex: 1;
  min-width: 0;
  color: #667085;
  font-size: 25rpx;
  line-height: 1.55;
}

.agreement-link {
  color: #2563eb;
  font-weight: 800;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(37, 99, 235, 0.26);
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-login-btn::after {
  border: 0;
}

.wechat-login-btn.loading {
  opacity: 0.78;
}

.wechat-login-btn.disabled {
  background: #a9b7cf;
  box-shadow: none;
}

.cancel-login {
  margin-top: 34rpx;
  text-align: center;
  color: #667085;
  font-size: 28rpx;
  font-weight: 700;
}
