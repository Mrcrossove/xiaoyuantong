.login-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding-left: 40rpx;
  padding-right: 40rpx;
  background: linear-gradient(180deg, #f7f9ff 0%, #ffffff 48%, #ffffff 100%);
}

.login-system-space {
  height: 120rpx;
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-logo {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 22rpx 46rpx rgba(57, 136, 228, 0.2);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-layer {
  position: absolute;
  width: 72rpx;
  height: 28rpx;
  border-radius: 6rpx;
  transform: skewY(-28deg) rotate(28deg);
}

.logo-layer.one {
  top: 50rpx;
  left: 38rpx;
  background: #35b7ae;
}

.logo-layer.two {
  top: 68rpx;
  left: 52rpx;
  background: #b9c4c7;
}

.logo-layer.three {
  top: 82rpx;
  left: 40rpx;
  background: #199f9c;
}

.brand-title {
  margin-top: 58rpx;
  color: #252a33;
  font-size: 54rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.brand-subtitle {
  margin-top: 22rpx;
  color: #a2a8b3;
  font-size: 30rpx;
  letter-spacing: 2rpx;
}

.login-actions {
  margin-top: 430rpx;
}

.wechat-login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 36rpx rgba(37, 99, 235, 0.26);
  display: flex;
  align-items: center;
  justify-content: center;
}

.wechat-login-btn::after {
  border: 0;
}

.wechat-login-btn.loading {
  opacity: 0.78;
}

.cancel-login {
  margin-top: 34rpx;
  text-align: center;
  color: #667085;
  font-size: 28rpx;
  font-weight: 700;
}
