<view class="page-shell" bindtap="closeFabMenu">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>

  <view class="topbar">
    <view class="topbar-left">
      <view class="circle-btn user-btn" bindtap="goProfileEdit">
        <image wx:if="{{!userAvatar.isDefaultAvatar}}" class="top-avatar-image" src="{{userAvatar.avatarUrl}}" mode="aspectFill"></image>
        <view wx:else class="top-avatar-default {{userAvatar.defaultAvatarClass}}"></view>
      </view>
    </view>
    <view class="topbar-title">校园通</view>
    <view class="topbar-right"></view>
  </view>

  <view wx:if="{{showFloatingCategories}}" class="floating-category-bar" style="top: calc({{statusBarHeight}}px + 88rpx);" catchtap="noop">
    <scroll-view scroll-x class="floating-category-scroll" enhanced show-scrollbar="{{false}}">
      <view class="floating-category-inner">
        <view
          class="floating-category-item {{activeServiceCategory === item.category ? 'active' : ''}}"
          wx:for="{{floatingCategories}}"
          wx:key="label"
          data-category="{{item.category}}"
          catchtap="selectServiceCategory"
        >
          {{item.label}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="search-row card">
    <view class="campus-pill" bindtap="openSchoolPicker">
      <view class="pin"></view>
      <text class="campus-text">{{selectedFeedLabel}}</text>
      <view class="campus-arrow"></view>
    </view>
    <view class="search-box">
      <view class="search-icon"></view>
      <input
        value="{{searchKeyword}}"
        placeholder="搜索校园内容"
        placeholder-class="placeholder"
        bindinput="onSearchKeywordInput"
        bindconfirm="openSearchPage"
        confirm-type="search"
      />
    </view>
    <view class="primary-btn" bindtap="openSearchPage">搜索</view>
  </view>

  <view class="banner card">
    <swiper
      class="banner-swiper"
      indicator-dots="{{displayBanners.length > 1}}"
      indicator-color="rgba(255,255,255,0.45)"
      indicator-active-color="#ffffff"
      circular="{{displayBanners.length > 1}}"
      autoplay="{{displayBanners.length > 1}}"
      interval="3500"
      duration="350"
      current="{{bannerCurrent}}"
      bindchange="onBannerChange"
    >
      <swiper-item wx:for="{{displayBanners}}" wx:key="id">
        <view class="banner-slide" data-link="{{item.linkUrl}}" data-is-default="{{item.isDefault}}" bindtap="openHomeBanner">
          <view wx:if="{{item.isDefault}}" class="banner-art">
            <view class="banner-copy">
              <text class="banner-tag">校园通后台招募</text>
              <view class="banner-title">校园管理员招募中</view>
              <view class="banner-desc">点击提交学校、团队人数和联系方式，平台审核后为你开通学校专属管理后台</view>
            </view>
            <view class="banner-badge">立即申请</view>
          </view>
          <image wx:else class="banner-image" src="{{item.imageUrl}}" mode="aspectFill"></image>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <view class="services card">
    <view
      class="service-item {{activeServiceCategory === item.category ? 'active' : ''}}"
      wx:for="{{services}}"
      wx:key="label"
      data-category="{{item.category}}"
      bindtap="selectServiceCategory"
    >
      <view class="service-icon service-{{item.icon}}"></view>
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="feed">
    <view class="post-card" wx:for="{{posts}}" wx:key="id" data-id="{{item.id}}" bindtap="openPostDetail">
      <view class="post-head">
        <view class="avatar">
          <image wx:if="{{!item.authorAvatar.isDefaultAvatar}}" class="post-avatar-image" src="{{item.authorAvatar.avatarUrl}}" mode="aspectFill"></image>
          <view wx:else class="post-avatar-default {{item.authorAvatar.defaultAvatarClass}}"></view>
        </view>
        <view>
          <view class="author-name">{{item.author}}</view>
          <view class="meta-row">
            <text class="school-name">{{item.school}}</text>
            <text class="tag tag-{{item.categoryView.theme}}">{{item.categoryView.primaryLabel}}</text>
          </view>
        </view>
        <text class="post-time">{{item.time}}</text>
      </view>
      <view class="post-title">{{item.title}}</view>
      <view class="post-text">{{item.content}}</view>
      <view class="image-grid">
        <view class="image-item {{img}}" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"></view>
      </view>
      <view class="post-foot">
        <text class="subtag subtag-{{item.categoryView.theme}}">{{item.categoryView.secondaryLabel}}</text>
        <view class="post-actions">
          <view class="post-action-item">
            <view class="post-action-icon comment"></view>
            <text>{{item.commentCount || 0}}</text>
          </view>
          <view class="post-action-item">
            <view class="post-action-icon like"></view>
            <text>{{item.likeCount || 0}}</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{postsLoading}}" class="empty-feed card">
      <view class="empty-feed-title">正在加载帖子</view>
      <view class="empty-feed-desc">
        {{selectedFeedMode === 'all' ? '正在获取全网热门内容，请稍候' : '正在获取当前高校的最新内容，请稍候'}}
      </view>
    </view>

    <view wx:elif="{{!posts.length}}" class="empty-feed card">
      <view class="empty-feed-title">
        {{postsErrorText || (selectedFeedMode === 'all' ? '全网暂时没有可展示的热门帖子' : '当前高校暂无帖子内容')}}
      </view>
      <view class="empty-feed-desc">
        {{postsErrorText ? '请稍后重试，或切换其他高校查看' : (selectedFeedMode === 'all' ? '可以切换具体高校继续浏览校园内容' : '可以切换其他高校，或稍后再来看看')}}
      </view>
      <view wx:if="{{!postsErrorText && selectedFeedMode != 'all'}}" class="empty-feed-actions">
        <view class="empty-feed-btn primary" catchtap="selectAllNetwork">去全网看看</view>
        <view class="empty-feed-btn" catchtap="toggleFabMenu">发布第一条</view>
      </view>
    </view>
  </view>

  <view class="fab-menu {{fabOpen ? 'open' : ''}}" catchtap="noop">
    <view
      class="fab-item"
      wx:for="{{fabOptions}}"
      wx:key="label"
      style="background: {{item.color}};"
      data-type="{{item.type}}"
      bindtap="onFabOptionTap"
    >
      <view class="fab-badge"></view>
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="fab" catchtap="toggleFabMenu">
    <text>+</text>
  </view>

  <view wx:if="{{showBackToFeed}}" class="back-to-feed" catchtap="scrollToFeedTop">
    <view class="back-to-feed-arrow"></view>
  </view>

  <view wx:if="{{schoolPickerOpen}}" class="overlay school-overlay" bindtap="closeSchoolPicker">
    <view class="school-picker card" catchtap="stopTap">
      <view class="school-picker-head">
        <view class="school-picker-title">切换首页范围</view>
        <view class="school-picker-close" bindtap="closeSchoolPicker">关闭</view>
      </view>
      <view class="school-picker-search">
        <view class="school-picker-search-box">
          <view class="search-icon"></view>
          <input
            value="{{schoolKeyword}}"
            placeholder="搜索学校"
            placeholder-class="placeholder"
            bindinput="onSchoolKeywordInput"
          />
        </view>
        <view class="school-all-btn {{selectedFeedMode === 'all' ? 'active' : ''}}" bindtap="selectAllNetwork">全网</view>
      </view>
      <scroll-view class="school-list" scroll-y enhanced show-scrollbar="{{false}}">
        <view wx:for="{{filteredProvinceSchoolGroups}}" wx:key="province" class="school-group">
          <view class="school-group-head" data-province="{{item.province}}" catchtap="toggleProvince">
            <view class="school-group-title">{{item.province}}</view>
            <view class="school-group-arrow {{item.expanded ? 'expanded' : ''}}"></view>
          </view>
          <view wx:if="{{item.expanded}}" class="school-group-body">
            <view
              class="school-item {{schoolItem === selectedFeedSchool && selectedFeedMode === 'school' ? 'active' : ''}}"
              wx:for="{{item.schools}}"
              wx:for-item="schoolItem"
              wx:key="*this"
              data-school="{{schoolItem}}"
              bindtap="selectSchool"
            >
              <text>{{schoolItem}}</text>
              <text wx:if="{{schoolItem === selectedFeedSchool && selectedFeedMode === 'school'}}" class="school-item-mark">当前</text>
            </view>
          </view>
        </view>
        <view wx:if="{{!filteredProvinceSchoolGroups.length}}" class="school-empty">没有匹配到高校</view>
      </scroll-view>
    </view>
  </view>

  <view class="tabbar card">
    <view class="tab active">
      <view class="tab-icon home"></view>
      <text>首页</text>
    </view>
    <view class="tab" bindtap="goStorefront">
      <view class="tab-icon shop"></view>
      <text>创业店铺</text>
    </view>
    <view class="tab" bindtap="goMessage">
      <view class="tab-icon message"></view>
      <text>消息</text>
    </view>
    <view class="tab" bindtap="goProfile">
      <view class="tab-icon user"></view>
      <text>我的</text>
    </view>
  </view>
</view>
