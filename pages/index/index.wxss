.search-row {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr) auto;
  gap: 12rpx;
  padding: 18rpx;
  align-items: center;
}

.user-btn {
  overflow: hidden;
}

.user-btn::before,
.user-btn::after {
  display: none;
}

.top-avatar-image,
.top-avatar-default {
  width: 100%;
  height: 100%;
}

.top-avatar-default {
  position: relative;
  background: linear-gradient(135deg, #23262f, #848a97);
}

.top-avatar-default::before {
  content: "";
  position: absolute;
  inset: 13rpx 15rpx 25rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.top-avatar-default::after {
  content: "";
  position: absolute;
  left: 13rpx;
  right: 13rpx;
  bottom: 11rpx;
  height: 18rpx;
  border-radius: 18rpx 18rpx 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.88);
}

.default-avatar-2 { background: linear-gradient(135deg, #22577a, #57cc99); }
.default-avatar-3 { background: linear-gradient(135deg, #5f4bb6, #a4b8ff); }
.default-avatar-4 { background: linear-gradient(135deg, #f97316, #ffd166); }
.default-avatar-5 { background: linear-gradient(135deg, #0f766e, #67e8f9); }
.default-avatar-6 { background: linear-gradient(135deg, #be185d, #f9a8d4); }
.default-avatar-7 { background: linear-gradient(135deg, #334155, #94a3b8); }
.default-avatar-8 { background: linear-gradient(135deg, #2563eb, #7dd3fc); }

.post-avatar-image,
.post-avatar-default {
  width: 100%;
  height: 100%;
}

.avatar::before,
.avatar::after {
  display: none;
}

.post-avatar-default {
  position: relative;
  background: linear-gradient(135deg, #ff8acd, #79adff);
}

.post-avatar-default::before {
  content: "";
  position: absolute;
  inset: 16rpx 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
}

.post-avatar-default::after {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 14rpx;
  height: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx 24rpx 34rpx 34rpx;
}

.campus-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  max-width: 240rpx;
  min-width: 0;
}

.campus-text {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 184rpx;
  color: #3f83ff;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #3f83ff;
  border-bottom: 4rpx solid #3f83ff;
  transform: rotate(45deg) translateY(-2rpx);
  flex: 0 0 auto;
}

.pin {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  background: #3f83ff;
  position: relative;
}

.pin::after {
  content: "";
  position: absolute;
  inset: 5rpx;
  border-radius: 50%;
  background: #ffffff;
}

.search-box {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #f2f5fa;
  border-radius: 999rpx;
  padding: 18rpx 22rpx;
}

.search-box input,
.school-picker-search input {
  flex: 1;
  min-width: 0;
}

.search-icon {
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid #9aa5bb;
  border-radius: 50%;
  position: relative;
  flex: 0 0 auto;
}

.search-icon::after {
  content: "";
  position: absolute;
  width: 10rpx;
  height: 4rpx;
  right: -8rpx;
  bottom: -3rpx;
  background: #9aa5bb;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.placeholder {
  color: #a3adbf;
}

.primary-btn {
  min-width: 104rpx;
  height: 68rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.22);
}

.floating-category-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 38;
  background: rgba(255, 255, 255, 0.96);
  border-bottom: 2rpx solid #edf1f6;
  box-shadow: 0 10rpx 24rpx rgba(39, 63, 116, 0.08);
}

.floating-category-scroll {
  width: 100%;
  white-space: nowrap;
}

.floating-category-inner {
  display: inline-flex;
  align-items: center;
  gap: 34rpx;
  min-width: 100%;
  box-sizing: border-box;
  padding: 22rpx 30rpx 18rpx;
}

.floating-category-item {
  position: relative;
  flex: 0 0 auto;
  color: #606a7d;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 42rpx;
}

.floating-category-item.active {
  color: #2f68e3;
  font-weight: 800;
}

.floating-category-item.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -10rpx;
  width: 44rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #2f68e3;
  transform: translateX(-50%);
}

.banner {
  margin-top: 24rpx;
  padding: 18rpx;
}

.banner-swiper {
  width: 100%;
  height: 286rpx;
}

.banner-slide {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  overflow: hidden;
}

.banner-art {
  width: 100%;
  height: 100%;
  display: grid;
  grid-template-columns: 1.35fr 0.9fr;
  background: linear-gradient(135deg, rgba(255, 230, 107, 0.96), rgba(255, 191, 68, 0.94));
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 28rpx;
}

.banner-art::before,
.banner-art::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: rgba(76, 124, 255, 0.16);
}

.banner-art::before {
  width: 320rpx;
  height: 320rpx;
  left: -90rpx;
  top: -120rpx;
}

.banner-art::after {
  width: 240rpx;
  height: 240rpx;
  right: -40rpx;
  bottom: -100rpx;
}

.banner-copy {
  position: relative;
  z-index: 1;
  padding: 34rpx;
  color: #19306b;
}

.banner-tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
  font-weight: 700;
}

.banner-title {
  margin-top: 8rpx;
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 800;
}

.banner-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.banner-badge {
  align-self: center;
  justify-self: center;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #173985;
  font-size: 36rpx;
  font-weight: 800;
  background: radial-gradient(circle at center, #ffe8a6 0 62rpx, #f0a24a 63rpx 72rpx, #4566ff 73rpx 100%);
  box-shadow: inset 0 0 0 14rpx #ffe57e;
  position: relative;
  z-index: 1;
}

.services {
  margin-top: 24rpx;
  padding: 26rpx 12rpx 22rpx;
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 2rpx;
  border: 2rpx solid rgba(231, 237, 248, 0.8);
  box-shadow: 0 18rpx 42rpx rgba(56, 82, 136, 0.08);
}

.service-item {
  display: grid;
  justify-items: center;
  align-content: start;
  gap: 12rpx;
  min-width: 0;
  color: #56657c;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1.2;
  transition: color 0.18s ease, transform 0.18s ease;
}

.service-item.active {
  color: #1f4fd1;
  font-weight: 800;
  transform: translateY(-2rpx);
}

.service-icon {
  width: 78rpx;
  height: 78rpx;
  border-radius: 28rpx;
  background: #f5f8ff;
  border: 2rpx solid rgba(226, 235, 250, 0.9);
  position: relative;
  box-shadow: 0 10rpx 20rpx rgba(54, 88, 156, 0.08);
  transition: background 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
}

.service-item.active .service-icon {
  background: #ffffff;
  border-color: rgba(47, 109, 240, 0.2);
  box-shadow: 0 14rpx 26rpx rgba(47, 109, 240, 0.16);
  transform: scale(1.04);
}

.service-all {
  background: linear-gradient(180deg, #eef4ff, #fbfdff);
}

.service-market {
  background: linear-gradient(180deg, #edf5ff, #f8fbff);
}

.service-job {
  background: linear-gradient(180deg, #f0f4ff, #fbfcff);
}

.service-rent {
  background: linear-gradient(180deg, #eef6ff, #fbfdff);
}

.service-chat {
  background: linear-gradient(180deg, #f1f6ff, #fbfdff);
}

.service-group {
  background: linear-gradient(180deg, #f0f7ff, #fbfdff);
}

.service-run {
  background: linear-gradient(180deg, #eef8ff, #fbfdff);
}

.service-market::before {
  content: "";
  position: absolute;
  left: 20rpx;
  top: 26rpx;
  width: 38rpx;
  height: 30rpx;
  border: 5rpx solid #2f7cff;
  border-radius: 10rpx;
  box-sizing: border-box;
}

.service-all::before {
  content: "";
  position: absolute;
  left: 19rpx;
  top: 19rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 6rpx;
  background: #4d75ff;
  box-shadow: 24rpx 0 0 #4d75ff, 0 24rpx 0 #4d75ff, 24rpx 24rpx 0 #4d75ff;
}

.service-market::after {
  content: "";
  position: absolute;
  left: 28rpx;
  top: 19rpx;
  width: 22rpx;
  height: 10rpx;
  border: 5rpx solid #2f7cff;
  border-bottom: 0;
  border-radius: 999rpx;
  box-sizing: border-box;
  background: transparent;
}

.service-job::before,
.service-rent::before,
.service-chat::before,
.service-group::before,
.service-run::before {
  content: "";
  position: absolute;
  border-color: #4d75ff;
}

.service-job::after {
  content: "";
  position: absolute;
  left: 29rpx;
  top: 20rpx;
  width: 20rpx;
  height: 12rpx;
  border: 5rpx solid #4d75ff;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
  box-sizing: border-box;
}

.service-job::before {
  left: 18rpx;
  top: 30rpx;
  width: 42rpx;
  height: 30rpx;
  border: 5rpx solid #4d75ff;
  border-radius: 10rpx;
  box-sizing: border-box;
}

.service-rent::after {
  content: "";
  position: absolute;
  left: 27rpx;
  top: 36rpx;
  width: 24rpx;
  height: 22rpx;
  border: 5rpx solid #3d7cff;
  border-radius: 7rpx 7rpx 0 0;
  box-sizing: border-box;
}

.service-rent::before {
  left: 18rpx;
  top: 18rpx;
  width: 42rpx;
  height: 42rpx;
  border-left: 5rpx solid #3d7cff;
  border-top: 5rpx solid #3d7cff;
  transform: rotate(45deg);
  border-radius: 8rpx 0 0 0;
}

.service-chat::after {
  content: "";
  position: absolute;
  left: 27rpx;
  top: 35rpx;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #4d75ff;
  box-shadow: 12rpx 0 0 #4d75ff, 24rpx 0 0 #4d75ff;
}

.service-chat::before {
  left: 17rpx;
  top: 21rpx;
  width: 44rpx;
  height: 32rpx;
  border: 5rpx solid #4d75ff;
  border-radius: 15rpx;
  box-sizing: border-box;
}

.service-group::after {
  content: "";
  position: absolute;
  left: 40rpx;
  top: 18rpx;
  width: 15rpx;
  height: 15rpx;
  border: 5rpx solid #4f86ff;
  border-radius: 50%;
  box-sizing: border-box;
}

.service-group::before {
  left: 18rpx;
  top: 22rpx;
  width: 18rpx;
  height: 18rpx;
  border: 5rpx solid #4f86ff;
  border-radius: 50%;
  box-sizing: border-box;
  box-shadow: 12rpx 21rpx 0 -4rpx #f0f7ff, 12rpx 21rpx 0 1rpx #4f86ff, 31rpx 18rpx 0 -4rpx #f0f7ff, 31rpx 18rpx 0 1rpx #4f86ff;
}

.service-run::after {
  content: "";
  position: absolute;
  left: 18rpx;
  top: 46rpx;
  width: 38rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #2f7cff;
  box-shadow: 12rpx -13rpx 0 #2f7cff;
}

.service-run::before {
  left: 23rpx;
  top: 18rpx;
  width: 24rpx;
  height: 24rpx;
  border-right: 5rpx solid #2f7cff;
  border-bottom: 5rpx solid #2f7cff;
  transform: rotate(-20deg);
}

.service-item.active .service-group::before {
  box-shadow: 12rpx 21rpx 0 -4rpx #ffffff, 12rpx 21rpx 0 1rpx #4f86ff, 31rpx 18rpx 0 -4rpx #ffffff, 31rpx 18rpx 0 1rpx #4f86ff;
}

.feed {
  margin-top: 24rpx;
  display: grid;
  gap: 24rpx;
}

.empty-feed {
  padding: 54rpx 36rpx;
  text-align: center;
}

.empty-feed-title {
  color: #202534;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-feed-desc {
  margin-top: 14rpx;
  color: #8590a7;
  font-size: 24rpx;
  line-height: 1.7;
}

.empty-feed-actions {
  margin-top: 26rpx;
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.empty-feed-btn {
  min-width: 176rpx;
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #f3f6fb;
  border: 2rpx solid #e5ebf5;
  color: #55637a;
  font-size: 24rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-feed-btn.primary {
  background: #2563eb;
  border-color: #2563eb;
  color: #ffffff;
  box-shadow: 0 12rpx 24rpx rgba(37, 99, 235, 0.2);
}

.post-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(53, 88, 163, 0.12);
  padding: 24rpx;
}

.post-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.post-text {
  margin-top: 12rpx;
  color: #414a5f;
  font-size: 28rpx;
  line-height: 1.7;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.tag-market { background: linear-gradient(135deg, #ffb15f, #f97316); }
.tag-job { background: linear-gradient(135deg, #5fa4ff, #2563eb); }
.tag-rent { background: linear-gradient(135deg, #65d58a, #16a34a); }
.tag-tree { background: linear-gradient(135deg, #f78acb, #c026d3); }
.tag-partner { background: linear-gradient(135deg, #a98bff, #7c3aed); }
.tag-errand { background: linear-gradient(135deg, #46d6d0, #0891b2); }
.tag-default { background: linear-gradient(135deg, #93a4bd, #64748b); }

.post-foot {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.subtag {
  min-height: 52rpx;
  padding: 0 22rpx;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
  box-sizing: border-box;
}

.subtag-market {
  color: #d97706;
  border-color: #f6a44f;
  background: #fff8ed;
}

.subtag-job {
  color: #2563eb;
  border-color: #82b4ff;
  background: #eff6ff;
}

.subtag-rent {
  color: #15803d;
  border-color: #82d99a;
  background: #f0fdf4;
}

.subtag-tree {
  color: #be185d;
  border-color: #f49ac7;
  background: #fdf2f8;
}

.subtag-partner {
  color: #6d28d9;
  border-color: #b49af8;
  background: #f5f3ff;
}

.subtag-errand {
  color: #0e7490;
  border-color: #67d9dc;
  background: #ecfeff;
}

.subtag-default {
  color: #475569;
  border-color: #cbd5e1;
  background: #f8fafc;
}

.post-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 24rpx;
  color: #8c97ab;
  font-size: 22rpx;
}

.post-action-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.post-action-icon {
  position: relative;
  flex: 0 0 auto;
}

.post-action-icon.comment {
  width: 24rpx;
  height: 18rpx;
  border: 3rpx solid #a5afc0;
  border-radius: 10rpx;
}

.post-action-icon.comment::after {
  content: "";
  position: absolute;
  left: 4rpx;
  bottom: -7rpx;
  width: 8rpx;
  height: 8rpx;
  border-left: 3rpx solid #a5afc0;
  border-bottom: 3rpx solid #a5afc0;
  background: #ffffff;
  transform: skewX(-18deg) rotate(-12deg);
}

.post-action-icon.like {
  width: 22rpx;
  height: 20rpx;
  transform: rotate(-45deg);
  border-left: 3rpx solid #a5afc0;
  border-bottom: 3rpx solid #a5afc0;
  border-radius: 4rpx 0 4rpx 8rpx;
}

.post-action-icon.like::before,
.post-action-icon.like::after {
  content: "";
  position: absolute;
  border: 3rpx solid #a5afc0;
  border-radius: 50%;
  background: #ffffff;
}

.post-action-icon.like::before {
  width: 12rpx;
  height: 12rpx;
  left: -3rpx;
  top: -10rpx;
}

.post-action-icon.like::after {
  width: 12rpx;
  height: 12rpx;
  left: 7rpx;
  top: 0rpx;
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: 246rpx;
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(37, 99, 235, 0.34);
  z-index: 40;
}

.fab text {
  color: #ffffff;
  font-size: 58rpx;
  line-height: 1;
}

.back-to-feed {
  position: fixed;
  right: 56rpx;
  bottom: 148rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.98);
  border: 2rpx solid #e5ebf5;
  box-shadow: 0 14rpx 28rpx rgba(32, 47, 82, 0.14);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 40;
}

.back-to-feed-arrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 5rpx solid #2f68e3;
  border-top: 5rpx solid #2f68e3;
  transform: rotate(45deg) translate(3rpx, 3rpx);
}

.fab-menu {
  position: fixed;
  right: 36rpx;
  bottom: 380rpx;
  display: grid;
  gap: 18rpx;
  opacity: 0;
  pointer-events: none;
  transform: translateY(20rpx) scale(0.95);
  transition: all 0.18s ease;
  z-index: 39;
}

.fab-menu.open {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0) scale(1);
}

.fab-item {
  min-width: 220rpx;
  min-height: 76rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  color: #20304f;
  background: rgba(255, 255, 255, 0.98);
  border: 2rpx solid #e5ebf5;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 16rpx 34rpx rgba(32, 47, 82, 0.14);
  font-size: 27rpx;
  font-weight: 800;
}

.fab-badge {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #2563eb;
}

.school-overlay {
  z-index: 80;
  display: block;
  padding: 170rpx 24rpx 0;
  box-sizing: border-box;
}

.school-picker {
  width: 580rpx;
  max-width: calc(100vw - 48rpx);
  max-height: 72vh;
  border-radius: 28rpx;
  padding: 24rpx 20rpx 20rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 60rpx rgba(33, 57, 115, 0.18);
}

.school-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-picker-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #202534;
}

.school-picker-close {
  color: #7f8aa0;
  font-size: 24rpx;
}

.school-picker-search {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 12rpx;
  align-items: center;
}

.school-picker-search-box {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  background: #f7f9fc;
  border: 2rpx solid #edf1f6;
  border-radius: 22rpx;
}

.school-picker-search-box input {
  width: 100%;
}

.school-all-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 22rpx;
  border: 2rpx solid #e5ebf5;
  background: #f5f7fb;
  color: #536179;
  font-size: 28rpx;
  font-weight: 800;
}

.school-all-btn.active {
  background: #2563eb;
  border-color: #2563eb;
  color: #ffffff;
}

.school-list {
  margin-top: 22rpx;
  max-height: 46vh;
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.school-group {
  margin-top: 0;
  border-bottom: 2rpx solid #eff3f8;
}

.school-group:last-child {
  border-bottom: 0;
}

.school-group-head {
  min-height: 104rpx;
  padding: 0 16rpx 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-group-title {
  color: #26324b;
  font-size: 32rpx;
  font-weight: 700;
}

.school-group-arrow {
  width: 18rpx;
  height: 18rpx;
  border-right: 4rpx solid #bbc5d6;
  border-bottom: 4rpx solid #bbc5d6;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
}

.school-group-arrow.expanded {
  transform: rotate(225deg);
}

.school-group-body {
  padding-bottom: 4rpx;
}

.school-item {
  min-height: 88rpx;
  padding: 0 8rpx 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 2rpx solid #eff3f8;
  color: #33405c;
  font-size: 28rpx;
}

.school-item.active {
  color: #2f6df0;
  font-weight: 700;
}

.school-item-mark {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf1ff;
  color: #2f6df0;
  font-size: 20rpx;
}

.school-empty {
  padding: 64rpx 0;
  text-align: center;
  color: #9ea8bb;
  font-size: 26rpx;
}
