.search-row {
  display: grid;
  grid-template-columns: 1.35fr 1.5fr auto;
  gap: 12rpx;
  padding: 18rpx;
  align-items: center;
}

.user-btn {
  overflow: hidden;
}

.user-btn::before,
.user-btn::after {
  display: none;
}

.top-avatar-image,
.top-avatar-default {
  width: 100%;
  height: 100%;
}

.top-avatar-default {
  position: relative;
  background: linear-gradient(135deg, #23262f, #848a97);
}

.top-avatar-default::before {
  content: "";
  position: absolute;
  inset: 13rpx 15rpx 25rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.88);
}

.top-avatar-default::after {
  content: "";
  position: absolute;
  left: 13rpx;
  right: 13rpx;
  bottom: 11rpx;
  height: 18rpx;
  border-radius: 18rpx 18rpx 24rpx 24rpx;
  background: rgba(255, 255, 255, 0.88);
}

.default-avatar-2 { background: linear-gradient(135deg, #22577a, #57cc99); }
.default-avatar-3 { background: linear-gradient(135deg, #5f4bb6, #a4b8ff); }
.default-avatar-4 { background: linear-gradient(135deg, #f97316, #ffd166); }
.default-avatar-5 { background: linear-gradient(135deg, #0f766e, #67e8f9); }
.default-avatar-6 { background: linear-gradient(135deg, #be185d, #f9a8d4); }
.default-avatar-7 { background: linear-gradient(135deg, #334155, #94a3b8); }
.default-avatar-8 { background: linear-gradient(135deg, #2563eb, #7dd3fc); }

.post-avatar-image,
.post-avatar-default {
  width: 100%;
  height: 100%;
}

.avatar::before,
.avatar::after {
  display: none;
}

.post-avatar-default {
  position: relative;
  background: linear-gradient(135deg, #ff8acd, #79adff);
}

.post-avatar-default::before {
  content: "";
  position: absolute;
  inset: 16rpx 20rpx 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 50%;
}

.post-avatar-default::after {
  content: "";
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 14rpx;
  height: 26rpx;
  background: rgba(255, 255, 255, 0.92);
  border-radius: 24rpx 24rpx 34rpx 34rpx;
}

.campus-pill {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.campus-text {
  flex: 1;
  min-width: 0;
  color: #3f83ff;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.campus-arrow {
  width: 14rpx;
  height: 14rpx;
  border-right: 4rpx solid #3f83ff;
  border-bottom: 4rpx solid #3f83ff;
  transform: rotate(45deg) translateY(-2rpx);
  flex: 0 0 auto;
}

.pin {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  background: #3f83ff;
  position: relative;
}

.pin::after {
  content: "";
  position: absolute;
  inset: 5rpx;
  border-radius: 50%;
  background: #ffffff;
}

.search-box {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #f2f5fa;
  border-radius: 999rpx;
  padding: 18rpx 22rpx;
}

.search-box input,
.school-picker-search input {
  flex: 1;
  min-width: 0;
}

.search-icon {
  width: 18rpx;
  height: 18rpx;
  border: 4rpx solid #9aa5bb;
  border-radius: 50%;
  position: relative;
  flex: 0 0 auto;
}

.search-icon::after {
  content: "";
  position: absolute;
  width: 10rpx;
  height: 4rpx;
  right: -8rpx;
  bottom: -3rpx;
  background: #9aa5bb;
  border-radius: 999rpx;
  transform: rotate(45deg);
}

.placeholder {
  color: #a3adbf;
}

.primary-btn {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #3f83ff, #6ea7ff);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
}

.banner {
  margin-top: 24rpx;
  padding: 18rpx;
}

.banner-swiper {
  width: 100%;
  height: 286rpx;
}

.banner-slide {
  width: 100%;
  height: 100%;
  border-radius: 28rpx;
  overflow: hidden;
}

.banner-art {
  width: 100%;
  height: 100%;
  display: grid;
  grid-template-columns: 1.35fr 0.9fr;
  background: linear-gradient(135deg, rgba(255, 230, 107, 0.96), rgba(255, 191, 68, 0.94));
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 28rpx;
}

.banner-art::before,
.banner-art::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  background: rgba(76, 124, 255, 0.16);
}

.banner-art::before {
  width: 320rpx;
  height: 320rpx;
  left: -90rpx;
  top: -120rpx;
}

.banner-art::after {
  width: 240rpx;
  height: 240rpx;
  right: -40rpx;
  bottom: -100rpx;
}

.banner-copy {
  position: relative;
  z-index: 1;
  padding: 34rpx;
  color: #19306b;
}

.banner-tag {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  font-size: 20rpx;
  font-weight: 700;
}

.banner-title {
  margin-top: 8rpx;
  font-size: 46rpx;
  line-height: 1.15;
  font-weight: 800;
}

.banner-desc {
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.6;
}

.banner-badge {
  align-self: center;
  justify-self: center;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #173985;
  font-size: 36rpx;
  font-weight: 800;
  background: radial-gradient(circle at center, #ffe8a6 0 62rpx, #f0a24a 63rpx 72rpx, #4566ff 73rpx 100%);
  box-shadow: inset 0 0 0 14rpx #ffe57e;
  position: relative;
  z-index: 1;
}

.services {
  margin-top: 24rpx;
  padding: 26rpx 10rpx 18rpx;
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 4rpx;
}

.service-item {
  display: grid;
  justify-items: center;
  gap: 10rpx;
  color: #51607b;
  font-size: 22rpx;
  transition: color 0.18s ease, transform 0.18s ease;
}

.service-item.active {
  color: #1f64e7;
  font-weight: 700;
  transform: translateY(-2rpx);
}

.service-icon {
  width: 86rpx;
  height: 86rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #f0f6ff, #dce8ff);
  position: relative;
  transition: background 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
}

.service-item.active .service-icon {
  background: linear-gradient(180deg, #3f83ff, #1f64e7);
  box-shadow: 0 14rpx 28rpx rgba(63, 131, 255, 0.32);
  transform: scale(1.04);
}

.service-market::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 30rpx;
  width: 32rpx;
  height: 24rpx;
  border: 4rpx solid #3f83ff;
  border-top: 0;
  border-radius: 0 0 8rpx 8rpx;
}

.service-market::after {
  content: "";
  position: absolute;
  left: 30rpx;
  top: 22rpx;
  width: 28rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #3f83ff;
  transform: rotate(14deg);
}

.service-job::before,
.service-rent::before,
.service-chat::before,
.service-group::before,
.service-run::before {
  content: "";
  position: absolute;
  inset: 22rpx;
  border-radius: 12rpx;
  background: #3f83ff;
}

.service-item.active .service-market::before {
  border-color: #ffffff;
}

.service-item.active .service-market::after,
.service-item.active .service-job::before,
.service-item.active .service-rent::before,
.service-item.active .service-chat::before,
.service-item.active .service-group::before,
.service-item.active .service-run::before {
  background: #ffffff;
}

.service-job::after {
  content: "";
  position: absolute;
  left: 34rpx;
  top: 34rpx;
  width: 20rpx;
  height: 6rpx;
  background: #dce8ff;
  box-shadow: 0 14rpx 0 #dce8ff;
}

.service-item.active .service-job::after {
  background: #3f83ff;
  box-shadow: 0 14rpx 0 #3f83ff;
}

.service-rent::after {
  content: "";
  position: absolute;
  left: 27rpx;
  top: 26rpx;
  width: 32rpx;
  height: 32rpx;
  background: #dce8ff;
  clip-path: polygon(50% 0, 100% 40%, 100% 100%, 0 100%, 0 40%);
}

.service-item.active .service-rent::after,
.service-item.active .service-chat::after,
.service-item.active .service-group::after,
.service-item.active .service-run::after {
  background: #3f83ff;
}

.service-chat::after {
  content: "";
  position: absolute;
  left: 30rpx;
  top: 32rpx;
  width: 26rpx;
  height: 20rpx;
  border-radius: 8rpx;
  background: #dce8ff;
}

.service-group::after {
  content: "";
  position: absolute;
  left: 24rpx;
  top: 34rpx;
  width: 38rpx;
  height: 22rpx;
  border-radius: 20rpx 20rpx 10rpx 10rpx;
  background: #dce8ff;
}

.service-run::after {
  content: "";
  position: absolute;
  left: 28rpx;
  top: 28rpx;
  width: 30rpx;
  height: 30rpx;
  background: #dce8ff;
  clip-path: polygon(12% 44%, 56% 44%, 75% 16%, 87% 24%, 71% 49%, 85% 49%, 85% 58%, 64% 58%, 47% 87%, 31% 80%, 42% 58%, 12% 58%);
}

.feed {
  margin-top: 24rpx;
  display: grid;
  gap: 24rpx;
}

.empty-feed {
  padding: 54rpx 36rpx;
  text-align: center;
}

.empty-feed-title {
  color: #202534;
  font-size: 32rpx;
  font-weight: 700;
}

.empty-feed-desc {
  margin-top: 14rpx;
  color: #8590a7;
  font-size: 24rpx;
  line-height: 1.7;
}

.post-card {
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 24rpx 60rpx rgba(53, 88, 163, 0.12);
  padding: 24rpx;
}

.post-title {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 800;
}

.post-text {
  margin-top: 12rpx;
  color: #414a5f;
  font-size: 28rpx;
  line-height: 1.7;
  display: -webkit-box;
  overflow: hidden;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
}

.post-actions {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 24rpx;
  color: #8c97ab;
  font-size: 22rpx;
}

.post-action-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
}

.post-action-icon {
  position: relative;
  flex: 0 0 auto;
}

.post-action-icon.comment {
  width: 24rpx;
  height: 18rpx;
  border: 3rpx solid #a5afc0;
  border-radius: 10rpx;
}

.post-action-icon.comment::after {
  content: "";
  position: absolute;
  left: 4rpx;
  bottom: -7rpx;
  width: 8rpx;
  height: 8rpx;
  border-left: 3rpx solid #a5afc0;
  border-bottom: 3rpx solid #a5afc0;
  background: #ffffff;
  transform: skewX(-18deg) rotate(-12deg);
}

.post-action-icon.like {
  width: 22rpx;
  height: 20rpx;
  transform: rotate(-45deg);
  border-left: 3rpx solid #a5afc0;
  border-bottom: 3rpx solid #a5afc0;
  border-radius: 4rpx 0 4rpx 8rpx;
}

.post-action-icon.like::before,
.post-action-icon.like::after {
  content: "";
  position: absolute;
  border: 3rpx solid #a5afc0;
  border-radius: 50%;
  background: #ffffff;
}

.post-action-icon.like::before {
  width: 12rpx;
  height: 12rpx;
  left: -3rpx;
  top: -10rpx;
}

.post-action-icon.like::after {
  width: 12rpx;
  height: 12rpx;
  left: 7rpx;
  top: 0rpx;
}

.fab {
  position: fixed;
  right: 36rpx;
  bottom: 186rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #57a4ff, #316df0);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(49, 109, 240, 0.38);
  z-index: 40;
}

.fab text {
  color: #ffffff;
  font-size: 64rpx;
  line-height: 1;
}

.fab-menu {
  position: fixed;
  right: 36rpx;
  bottom: 320rpx;
  display: grid;
  gap: 18rpx;
  opacity: 0;
  pointer-events: none;
  transform: translateY(20rpx) scale(0.95);
  transition: all 0.18s ease;
  z-index: 39;
}

.fab-menu.open {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0) scale(1);
}

.fab-item {
  min-width: 220rpx;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 24rpx 60rpx rgba(53, 88, 163, 0.12);
  font-size: 28rpx;
  font-weight: 700;
}

.fab-badge {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.24);
}

.school-overlay {
  z-index: 80;
  display: block;
  padding: 170rpx 24rpx 0;
  box-sizing: border-box;
}

.school-picker {
  width: 580rpx;
  max-width: calc(100vw - 48rpx);
  max-height: 72vh;
  border-radius: 28rpx;
  padding: 24rpx 20rpx 20rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 60rpx rgba(33, 57, 115, 0.18);
}

.school-picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-picker-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #202534;
}

.school-picker-close {
  color: #7f8aa0;
  font-size: 24rpx;
}

.school-picker-search {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx;
  gap: 12rpx;
  align-items: center;
}

.school-picker-search-box {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 20rpx;
  background: #f7f9fc;
  border: 2rpx solid #edf1f6;
  border-radius: 22rpx;
}

.school-picker-search-box input {
  width: 100%;
}

.school-all-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 22rpx;
  border: 3rpx solid #80aef7;
  background: #ffffff;
  color: #3f83ff;
  font-size: 28rpx;
  font-weight: 700;
}

.school-all-btn.active {
  background: rgba(63, 131, 255, 0.12);
}

.school-list {
  margin-top: 22rpx;
  max-height: 46vh;
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
}

.school-group {
  margin-top: 0;
  border-bottom: 2rpx solid #eff3f8;
}

.school-group:last-child {
  border-bottom: 0;
}

.school-group-head {
  min-height: 104rpx;
  padding: 0 16rpx 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.school-group-title {
  color: #26324b;
  font-size: 32rpx;
  font-weight: 700;
}

.school-group-arrow {
  width: 18rpx;
  height: 18rpx;
  border-right: 4rpx solid #bbc5d6;
  border-bottom: 4rpx solid #bbc5d6;
  transform: rotate(45deg);
  transition: transform 0.2s ease;
}

.school-group-arrow.expanded {
  transform: rotate(225deg);
}

.school-group-body {
  padding-bottom: 4rpx;
}

.school-item {
  min-height: 88rpx;
  padding: 0 8rpx 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  border-bottom: 2rpx solid #eff3f8;
  color: #33405c;
  font-size: 28rpx;
}

.school-item.active {
  color: #2f6df0;
  font-weight: 700;
}

.school-item-mark {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eaf1ff;
  color: #2f6df0;
  font-size: 20rpx;
}

.school-empty {
  padding: 64rpx 0;
  text-align: center;
  color: #9ea8bb;
  font-size: 26rpx;
}
